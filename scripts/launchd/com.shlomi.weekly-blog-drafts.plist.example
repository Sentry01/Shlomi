<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.shlomi.weekly-blog-drafts</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>-lc</string>
      <string>cd /Users/shlomi/Projects/shlomi &amp;&amp; node scripts/blog-ops.mjs list --ready-only &gt;&gt; "$HOME/Library/Logs/weekly-blog-drafts.log"</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/shlomi/Projects/shlomi</string>

    <key>StartCalendarInterval</key>
    <dict>
      <key>Weekday</key>
      <integer>1</integer>
      <key>Hour</key>
      <integer>8</integer>
      <key>Minute</key>
      <integer>30</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/shlomi/Library/Logs/weekly-blog-drafts.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/shlomi/Library/Logs/weekly-blog-drafts.log</string>
  </dict>
</plist>

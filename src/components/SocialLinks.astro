---
/**
 * SocialLinks — outbound links to GitHub and LinkedIn.
 * Renders as a compact inline list with hover/focus states.
 * No email or phone.
 */
interface Props {
  class?: string;
  tone?: 'default' | 'inverse';
}

const { class: className, tone = 'default' } = Astro.props;

const links = [
  {
    label: 'GitHub',
    href: 'https://github.com/Sentry01',
    icon: 'github',
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/shlomi',
    icon: 'linkedin',
  },
];
---

<ul class:list={['social-links', `social-links--${tone}`, className]} role="list">
  {links.map(({ label, href, icon }) => (
    <li>
      <a
        href={href}
        class="social-links__link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${label} (opens in new tab)`}
      >
        <span class="social-links__icon" aria-hidden="true">
          {icon === 'github' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          )}
          {icon === 'linkedin' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          )}
        </span>
        <span class="social-links__label">{label}</span>
      </a>
    </li>
  ))}
</ul>

<style>
  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    list-style: none;
  }

  .social-links__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    min-block-size: 2.25rem;
    padding: 0 var(--space-3);
    border: 1px solid rgba(26, 26, 26, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    box-shadow: 0 10px 24px rgba(48, 38, 44, 0.06);
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 500;
    line-height: 1;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .social-links__link:hover {
    color: var(--color-text);
    border-color: rgba(26, 26, 26, 0.16);
    background: rgba(255, 255, 255, 0.9);
    transform: translateY(-1px);
  }

  .social-links__link:focus-visible {
    color: var(--color-text);
  }

  .social-links__icon {
    inline-size: 1rem;
    block-size: 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .social-links__icon svg {
    inline-size: 100%;
    block-size: 100%;
    display: block;
  }

  .social-links--inverse .social-links__link {
    color: var(--color-bg);
    background: rgba(26, 26, 26, 0.16);
    border-color: rgba(250, 250, 250, 0.18);
    box-shadow: none;
  }

  .social-links--inverse .social-links__link:hover,
  .social-links--inverse .social-links__link:focus-visible {
    color: var(--color-bg);
    background: rgba(26, 26, 26, 0.28);
    border-color: rgba(250, 250, 250, 0.3);
  }

  .social-links__label {
    /* Hidden on small viewports to keep footer compact */
  }

  @media (max-width: 30rem) {
    .social-links__link {
      min-inline-size: 2.25rem;
      justify-content: center;
      padding-inline: var(--space-2);
    }

    .social-links__label {
      position: absolute;
      inline-size: 1px;
      block-size: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }
</style>

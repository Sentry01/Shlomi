---
/**
 * BlogPostCard — Presentational card for a blog post entry.
 *
 * All props are optional to handle missing metadata gracefully.
 * When `href` is provided, the card becomes a clickable link.
 * Set `isExternal` to show a badge and open in a new tab.
 */
interface Props {
  title?: string;
  description?: string;
  pubDate?: Date | string;
  tags?: string[];
  readingTime?: string;
  href?: string;
  /** When true, marks the card as linking to an external original. */
  isExternal?: boolean;
}

const { title, description, pubDate, tags, readingTime, href, isExternal } = Astro.props;

const dateValue = pubDate ? new Date(pubDate) : null;
const isValidDate = !!dateValue && !Number.isNaN(dateValue.getTime());
const formattedDate = isValidDate
  ? dateValue.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      timeZone: 'UTC',
    })
  : null;

const Tag = href ? 'a' : 'div';
const linkProps = href
  ? {
      href,
      class: 'card card--linked blog-card',
      ...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}),
    }
  : { class: 'card blog-card' };
---

<Tag {...linkProps}>
  <div class="blog-card__header">
    {(formattedDate || readingTime) && (
      <div class="blog-card__meta text-muted text-xs">
        {formattedDate && (
          <time class="blog-card__date" datetime={dateValue?.toISOString()}>
            {formattedDate}
          </time>
        )}
        {formattedDate && readingTime && (
          <span aria-hidden="true" class="blog-card__separator">·</span>
        )}
        {readingTime && <span>{readingTime}</span>}
      </div>
    )}

    {title && <h3 class="blog-card__title">{title}</h3>}

    {isExternal && (
      <span class="blog-card__external text-muted text-xs">
        <span class="blog-card__external-icon" aria-hidden="true">↗</span>
        <span>Originally published externally</span>
      </span>
    )}
  </div>

  {description && (
    <p class="blog-card__desc">{description}</p>
  )}

  {tags && tags.length > 0 && (
    <ul class="blog-card__tags" role="list">
      {tags.map((tag) => (
        <li><span class="tag">{tag}</span></li>
      ))}
    </ul>
  )}
</Tag>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    block-size: 100%;
  }

  .blog-card__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .blog-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }

  .blog-card__date {
    font-weight: 500;
  }

  .blog-card__separator {
    color: var(--color-border-hover);
  }

  .blog-card__title {
    font-size: var(--text-xl);
    font-weight: 600;
    line-height: var(--leading-snug);
  }

  .card--linked .blog-card__title {
    color: var(--color-text);
  }

  .blog-card__external {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    inline-size: fit-content;
    padding: var(--space-1) var(--space-2);
    border-radius: 999px;
    background: rgba(74, 124, 155, 0.08);
    font-style: italic;
  }

  .blog-card__external-icon {
    line-height: 1;
    transform: translateY(-1px);
  }

  .blog-card__desc {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  .blog-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin-block-start: auto;
  }
</style>

---
import ShowcasePreviewCard from '@/components/ShowcasePreviewCard.astro';

interface ShowcaseMarqueeItem {
  label: string;
  title: string;
  href: string;
  image?: string;
  imageAlt?: string;
  meta?: string;
  description?: string;
  external?: boolean;
}

interface Props {
  items?: ShowcaseMarqueeItem[];
  ariaLabel?: string;
}

const {
  items = [],
  ariaLabel = 'Highlighted projects, articles, and speaking appearances',
} = Astro.props;

const marqueeItems = items.length > 0 ? [...items, ...items] : [];
const durationSeconds = items.length > 0 ? Math.max(items.length * 14, 140) : 140;
---

{items.length > 0 ? (
  <div class="showcase-marquee" aria-label={ariaLabel} style={`--marquee-duration: ${durationSeconds}s;`}>
    <div class="showcase-marquee__viewport">
      <div class="showcase-marquee__track">
        {marqueeItems.map((item, index) => {
          const isDuplicate = index >= items.length;

          return (
          <div
            class:list={[
              'showcase-marquee__item',
              { 'showcase-marquee__item--duplicate': isDuplicate },
            ]}
            aria-hidden={isDuplicate ? 'true' : undefined}
          >
            <ShowcasePreviewCard
              label={item.label}
              title={item.title}
              href={item.href}
              image={item.image}
              imageAlt={item.imageAlt}
              meta={item.meta}
              description={item.description}
              external={item.external}
              tabIndex={isDuplicate ? -1 : undefined}
              variant="compact"
            />
          </div>
          );
        })}
      </div>
    </div>
  </div>
) : (
  <p class="showcase-marquee__empty">Highlights will appear here soon.</p>
)}

<style>
  .showcase-marquee {
    position: relative;
  }

  .showcase-marquee__viewport {
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent, black 7%, black 93%, transparent);
  }

  .showcase-marquee__track {
    display: flex;
    align-items: stretch;
    gap: var(--space-4);
    width: max-content;
    animation: showcase-marquee var(--marquee-duration, 120s) linear infinite;
  }

  .showcase-marquee__item {
    flex: none;
  }

  .showcase-marquee:is(:hover, :focus-within) .showcase-marquee__track {
    animation-play-state: paused;
  }

  .showcase-marquee__empty {
    color: var(--color-text-muted);
  }

  @keyframes showcase-marquee {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(calc(-50% - (var(--space-4) / 2)));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .showcase-marquee__viewport {
      overflow-x: auto;
      mask-image: none;
      padding-block-end: var(--space-2);
    }

    .showcase-marquee__track {
      animation: none;
    }
  }
</style>

---
/**
 * Hero — Editorial hero shell with cinematic framing.
 *
 * Supports optional content through named slots:
 *   - default slot: body text / description
 *   - eyebrow: small label above the title
 *   - title: main heading (falls back to `heading` prop)
 *   - actions: CTA buttons / links
 *
 * Optional props:
 *   - heading: fallback heading text if no `title` slot is provided
 *   - backgroundImage: URL for a cinematic background image
 *   - overlay: whether to add a dark gradient overlay for text readability (default true)
 *   - fullHeight: whether the hero spans the full viewport height (default false)
 */
interface Props {
  heading?: string;
  backgroundImage?: string;
  imageLayout?: 'background' | 'panel';
  overlay?: boolean;
  fullHeight?: boolean;
  class?: string;
}

const {
  heading,
  backgroundImage,
  imageLayout = 'background',
  overlay = true,
  fullHeight = false,
  class: className,
} = Astro.props;

const hasImage = !!backgroundImage;
const useImagePanel = hasImage && imageLayout === 'panel';
const normalizedBackgroundImage =
  backgroundImage?.startsWith('/')
    ? `${import.meta.env.BASE_URL}${backgroundImage.replace(/^\/+/, '')}`
    : backgroundImage;
---

<section
  class:list={[
    'hero',
    { 'hero--with-image': hasImage && !useImagePanel },
    { 'hero--panel': useImagePanel },
    { 'hero--full': fullHeight },
    className,
  ]}
  style={hasImage ? `--hero-bg: url('${normalizedBackgroundImage}')` : undefined}
>
  {hasImage && overlay && !useImagePanel && <div class="hero__overlay" aria-hidden="true" />}

  <div class="hero__frame container">
    <div class="hero__content">
      <slot name="eyebrow">
        {/* Empty if no eyebrow provided — renders nothing */}
      </slot>

      <slot name="title">
        {heading && <h1 class="hero__heading">{heading}</h1>}
      </slot>

      <div class="hero__body">
        <slot />
      </div>

      <slot name="actions">
        {/* Empty if no actions provided — renders nothing */}
      </slot>
    </div>

    {useImagePanel && <div class="hero__visual" aria-hidden="true" />}
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    padding-block: var(--space-16) var(--space-12);
    min-block-size: 20rem;
    overflow: hidden;
  }

  .hero--full {
    min-block-size: 85dvh;
  }

  .hero__frame {
    position: relative;
    z-index: 1;
    inline-size: 100%;
  }

  /* ----- Background Image ----- */
  .hero--with-image {
    background-image: var(--hero-bg);
    background-size: cover;
    background-position: center top;
    background-repeat: no-repeat;
    color: var(--color-bg);
  }

  /* Cinematic gradient overlay — dark from bottom for text readability */
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.7) 0%,
      rgba(0, 0, 0, 0.35) 40%,
      rgba(0, 0, 0, 0.1) 70%,
      transparent 100%
    );
    pointer-events: none;
  }

  /* ----- Content ----- */
  .hero__content {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-inline-size: var(--prose-max);
  }

  .hero__heading {
    font-size: var(--text-4xl);
    font-weight: 700;
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
  }

  .hero--with-image .hero__heading {
    color: var(--color-bg);
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
  }

  .hero__body {
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    max-inline-size: 36rem;
  }

  .hero__body:empty {
    display: none;
  }

  .hero--with-image .hero__body {
    color: rgba(250, 250, 250, 0.9);
  }

  /* Eyebrow slot styling — expected to contain a <span> or <p> */
  .hero__content :global([slot='eyebrow']),
  .hero__content :global(.hero-eyebrow) {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }

  .hero--with-image .hero__content :global([slot='eyebrow']),
  .hero--with-image .hero__content :global(.hero-eyebrow) {
    color: rgba(250, 250, 250, 0.75);
  }

  /* Actions slot — expected to contain links/buttons */
  .hero__content :global([slot='actions']) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-block-start: var(--space-4);
  }

  .hero--panel {
    align-items: center;
    padding-block: clamp(var(--space-10), 8vw, var(--space-16));
    background:
      radial-gradient(circle at top left, rgba(235, 214, 225, 0.58), transparent 38%),
      linear-gradient(140deg, #faf8f6 0%, #f0eeec 48%, #e8e1e5 100%);
    color: var(--color-text);
  }

  .hero--panel.hero--full {
    min-block-size: clamp(34rem, 78dvh, 48rem);
  }

  .hero--panel .hero__frame {
    display: grid;
    gap: clamp(var(--space-6), 4vw, var(--space-10));
    align-items: center;
  }

  .hero--panel .hero__content {
    max-inline-size: none;
    padding: clamp(var(--space-6), 4vw, var(--space-10));
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: clamp(1.25rem, 2vw, 1.75rem);
    background:
      linear-gradient(155deg, rgba(255, 255, 255, 0.78) 0%, rgba(255, 255, 255, 0.52) 100%);
    box-shadow: 0 24px 64px rgba(85, 72, 78, 0.14);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .hero--panel .hero__heading {
    color: var(--color-text);
    text-shadow: none;
  }

  .hero--panel .hero__body {
    max-inline-size: 34rem;
    color: rgba(26, 26, 26, 0.78);
  }

  .hero--panel .hero__content :global([slot='eyebrow']),
  .hero--panel .hero__content :global(.hero-eyebrow) {
    color: rgba(53, 47, 50, 0.64);
  }

  .hero__visual {
    position: relative;
    min-block-size: clamp(18rem, 44vw, 32rem);
    block-size: 100%;
    border-radius: clamp(1.25rem, 2vw, 1.75rem);
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(15, 19, 27, 0.12)),
      var(--hero-bg) center 28% / cover no-repeat;
    box-shadow: 0 28px 72px rgba(33, 35, 48, 0.22);
  }

  .hero__visual::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(248, 241, 245, 0.12), transparent 38%),
      linear-gradient(0deg, rgba(22, 24, 36, 0.16), rgba(22, 24, 36, 0.04));
    pointer-events: none;
  }

  @media (min-width: 64rem) {
    .hero--panel .hero__frame {
      grid-template-columns: minmax(0, 2fr) minmax(0, 3fr);
    }
  }
</style>

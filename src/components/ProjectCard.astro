---
/**
 * ProjectCard — Presentational card for a project entry.
 *
 * All props are optional to handle missing metadata gracefully.
 * When `href` is provided, the card becomes a clickable link.
 */
interface Props {
  title?: string;
  description?: string;
  tags?: string[];
  href?: string;
  repo?: string;
  repoUrl?: string;
  liveUrl?: string;
}

const { title, description, tags, href, repo, repoUrl, liveUrl } = Astro.props;

const hasResourceLinks = Boolean(repoUrl || liveUrl);
const RootTag = href && !hasResourceLinks ? 'a' : 'article';
const rootProps = href && !hasResourceLinks
  ? { href, class: 'card card--linked project-card' }
  : { class: 'card project-card' };
---

<RootTag {...rootProps}>
  {title && (
    <h3 class="project-card__title">
      {href && hasResourceLinks ? (
        <a href={href} class="project-card__title-link">
          {title}
        </a>
      ) : (
        title
      )}
    </h3>
  )}

  {description && (
    <p class="project-card__desc">{description}</p>
  )}

  <div class="project-card__meta">
    {tags && tags.length > 0 && (
      <ul class="project-card__tags" role="list">
        {tags.map((tag) => (
          <li><span class="tag">{tag}</span></li>
        ))}
      </ul>
    )}

    {(repoUrl || liveUrl) ? (
      <div class="project-card__links">
        {href && (
          <a href={href} class="project-card__link project-card__link--primary">
            <span>Overview</span>
            <span class="project-card__link-icon" aria-hidden="true">→</span>
          </a>
        )}
        {repoUrl && (
          <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="project-card__link">
            <span>Source</span>
            <span class="project-card__link-icon" aria-hidden="true">↗</span>
          </a>
        )}
        {liveUrl && (
          <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="project-card__link">
            <span>Live</span>
            <span class="project-card__link-icon" aria-hidden="true">↗</span>
          </a>
        )}
      </div>
    ) : repo ? (
      <span class="project-card__repo text-muted text-xs">
        {repo}
      </span>
    ) : null}
  </div>
</RootTag>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    block-size: 100%;
  }

  .project-card__title {
    font-size: var(--text-xl);
    font-weight: 600;
    line-height: var(--leading-snug);
  }

  a.project-card__title,
  .card--linked .project-card__title {
    color: var(--color-text);
  }

  .project-card__title-link {
    color: inherit;
    text-decoration: none;
  }

  .project-card__title-link:hover {
    text-decoration: underline;
  }

  .project-card__desc {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  .project-card__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: var(--space-4);
    margin-block-start: auto;
    padding-block-start: var(--space-4);
    border-block-start: 1px solid rgba(26, 26, 26, 0.08);
  }

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
  }

  .project-card__repo {
    margin-inline-start: auto;
  }

  .project-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-inline-start: auto;
  }

  .project-card__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    min-block-size: 2.25rem;
    padding-inline: var(--space-3);
    border: 1px solid rgba(26, 26, 26, 0.1);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.76);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .project-card__link--primary {
    background: var(--color-accent);
    border-color: transparent;
    color: var(--color-text);
  }

  .project-card__link-icon {
    line-height: 1;
    transform: translateY(-1px);
  }

  .project-card__link:hover {
    text-decoration: none;
    border-color: rgba(26, 26, 26, 0.2);
    background: rgba(255, 255, 255, 0.92);
    transform: translateY(-1px);
  }

  .project-card__link--primary:hover {
    border-color: transparent;
    background: var(--color-accent-hover);
    color: var(--color-text);
    box-shadow: 0 12px 22px rgba(31, 199, 191, 0.22);
  }
</style>

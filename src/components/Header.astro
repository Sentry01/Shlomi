---
interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;

const navLinks = [
  { label: 'About', href: `${import.meta.env.BASE_URL}about/` },
  { label: 'Projects', href: `${import.meta.env.BASE_URL}projects/` },
  { label: 'Blog', href: `${import.meta.env.BASE_URL}blog/` },
  { label: 'Speaking', href: `${import.meta.env.BASE_URL}speaking/` },
];

function isActive(href: string): boolean {
  if (!currentPath) return false;
  return currentPath.startsWith(href);
}
---

<header class="site-header">
  <div class="site-header__inner container">
    <div class="site-header__shell">
      <a href={import.meta.env.BASE_URL} class="site-header__wordmark">
        Shlomi Shaki
      </a>

      {/* Desktop nav — visible at wider viewports */}
      <nav class="site-header__nav" aria-label="Main navigation">
        <ul class="site-header__list" role="list">
          {navLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class:list={['site-header__link', { 'is-active': isActive(href) }]}
                aria-current={isActive(href) ? 'page' : undefined}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      {/* Mobile nav — native disclosure for keyboard a11y */}
      <details class="site-header__mobile-nav">
        <summary class="site-header__menu-btn" aria-label="Toggle navigation menu">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line class="menu-line menu-line--top" x1="3" y1="6" x2="21" y2="6" />
            <line class="menu-line menu-line--mid" x1="3" y1="12" x2="21" y2="12" />
            <line class="menu-line menu-line--bot" x1="3" y1="18" x2="21" y2="18" />
          </svg>
        </summary>

        <nav class="site-header__dropdown" aria-label="Mobile navigation">
          <ul role="list">
            {navLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class:list={['site-header__dropdown-link', { 'is-active': isActive(href) }]}
                  aria-current={isActive(href) ? 'page' : undefined}
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </details>
    </div>
  </div>
</header>

<style>
  /* ----- Header Shell ----- */
  .site-header {
    position: sticky;
    inset-block-start: 0;
    z-index: 100;
    padding-block: var(--space-3);
    background: linear-gradient(180deg, rgba(244, 240, 235, 0.94), rgba(244, 240, 235, 0.72));
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
  }

  .site-header__shell {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    inline-size: 100%;
    min-block-size: 4.25rem;
    padding-inline: clamp(var(--space-4), 2vw, var(--space-6));
    border: 1px solid rgba(17, 17, 17, 0.06);
    border-radius: 1.25rem;
    background: rgba(255, 253, 248, 0.78);
    box-shadow: 0 16px 40px rgba(17, 17, 17, 0.06);
  }

  /* ----- Wordmark ----- */
  .site-header__wordmark {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 0.95rem + 0.3vw, 1.2rem);
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  .site-header__wordmark:hover {
    color: var(--color-accent);
  }

  /* ----- Desktop Nav ----- */
  .site-header__nav {
    display: none;
  }

  .site-header__list {
    display: flex;
    gap: var(--space-2);
    list-style: none;
  }

  .site-header__link {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-muted);
    text-decoration: none;
    letter-spacing: 0.01em;
    min-block-size: 2.5rem;
    padding-inline: var(--space-4);
    position: relative;
    border-radius: 999px;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .site-header__link::after {
    content: '';
    position: absolute;
    inset: auto var(--space-4) var(--space-2);
    block-size: 1.5px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .site-header__link:hover,
  .site-header__link.is-active {
    color: var(--color-text);
    background: rgba(31, 199, 191, 0.1);
  }

  .site-header__link.is-active::after,
  .site-header__link:hover::after {
    transform: scaleX(1);
  }

  /* ----- Mobile Nav (details/summary) ----- */
  .site-header__mobile-nav {
    display: block;
    position: relative;
  }

  .site-header__menu-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    inline-size: 2.75rem;
    block-size: 2.75rem;
    color: var(--color-text);
    list-style: none;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(17, 17, 17, 0.06);
  }

  /* Remove default marker in Safari/Chrome */
  .site-header__menu-btn::-webkit-details-marker {
    display: none;
  }

  .site-header__menu-btn::marker {
    display: none;
    content: '';
  }

  .site-header__dropdown {
    position: absolute;
    inset-inline-end: 0;
    inset-block-start: calc(100% + var(--space-2));
    min-inline-size: min(18rem, calc(100vw - (2 * var(--container-pad))));
    background: rgba(255, 253, 248, 0.98);
    border: 1px solid rgba(17, 17, 17, 0.06);
    border-radius: 1.25rem;
    box-shadow: 0 20px 50px rgba(17, 17, 17, 0.08);
    padding: var(--space-3);
  }

  .site-header__dropdown ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .site-header__dropdown-link {
    display: block;
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-muted);
    text-decoration: none;
    border-radius: 999px;
    transition: background var(--duration-fast) var(--ease-out),
                color var(--duration-fast) var(--ease-out);
  }

  .site-header__dropdown-link:hover,
  .site-header__dropdown-link.is-active {
    background: rgba(31, 199, 191, 0.12);
    color: var(--color-text);
  }

  /* ----- Responsive Breakpoint ----- */
  @media (min-width: 48rem) {
    .site-header__nav {
      display: block;
    }

    .site-header__mobile-nav {
      display: none;
    }
  }
</style>

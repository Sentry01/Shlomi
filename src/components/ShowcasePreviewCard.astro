---
interface Props {
  label: string;
  title: string;
  href?: string;
  image?: string;
  imageAlt?: string;
  meta?: string;
  description?: string;
  external?: boolean;
  tags?: string[];
  repoUrl?: string;
  liveUrl?: string;
  variant?: 'default' | 'compact';
  tabIndex?: number;
}

const {
  label,
  title,
  href,
  image,
  imageAlt = title,
  meta,
  description,
  external = false,
  tags,
  repoUrl,
  liveUrl,
  variant = 'default',
  tabIndex,
} = Astro.props;

const normalizedImage =
  image && image.startsWith('/') && !image.startsWith('//')
    ? `${import.meta.env.BASE_URL}${image.slice(1)}`
    : image;

const hasResourceLinks = Boolean(repoUrl || liveUrl);
const Tag = href && !hasResourceLinks ? 'a' : 'article';
---

<Tag
  href={href && !hasResourceLinks ? href : undefined}
  tabindex={href && !hasResourceLinks ? tabIndex : undefined}
  class:list={[
    'showcase-preview',
    `showcase-preview--${variant}`,
    { 'showcase-preview--linked': Boolean(href && !hasResourceLinks) },
  ]}
  target={external && !hasResourceLinks ? '_blank' : undefined}
  rel={external && !hasResourceLinks ? 'noopener noreferrer' : undefined}
>
  <div class="showcase-preview__media">
    {normalizedImage ? (
      <img
        src={normalizedImage}
        alt={imageAlt}
        width="1280"
        height="720"
        class="showcase-preview__image"
        loading={variant === 'compact' ? 'lazy' : 'eager'}
        decoding="async"
      />
    ) : hasResourceLinks ? (
      <div class="showcase-preview__links">
        {href && (
          <a href={href} class="showcase-preview__action showcase-preview__action--primary">
            <span>Overview</span>
            <span class="showcase-preview__action-icon" aria-hidden="true">→</span>
          </a>
        )}
        {repoUrl && (
          <a
            href={repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="showcase-preview__action"
          >
            <span>Source</span>
            <span class="showcase-preview__action-icon" aria-hidden="true">↗</span>
          </a>
        )}
        {liveUrl && (
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="showcase-preview__action"
          >
            <span>Live</span>
            <span class="showcase-preview__action-icon" aria-hidden="true">↗</span>
          </a>
        )}
      </div>
    ) : tags && tags.length > 0 ? (
      <div class="showcase-preview__tags-area">
        <ul class="showcase-preview__tags" role="list" aria-label={`${label} tags`}>
          {tags.map((tag) => (
            <li><span class="tag">{tag}</span></li>
          ))}
        </ul>
      </div>
    ) : (
      <div class="showcase-preview__fallback" aria-hidden="true">
        <span class="showcase-preview__fallback-copy">Placeholder</span>
      </div>
    )}

    <span class="showcase-preview__label">{label}</span>
  </div>

  <div class="showcase-preview__body">
    <div class="showcase-preview__copy">
      {meta && <p class="showcase-preview__meta">{meta}</p>}
      <h3 class="showcase-preview__title">
        {href && hasResourceLinks ? (
          <a href={href} class="showcase-preview__title-link">{title}</a>
        ) : (
          title
        )}
      </h3>
      {description && (
        <p class="showcase-preview__description">{description}</p>
      )}
    </div>

    {href && !hasResourceLinks && (
      <span class="showcase-preview__icon" aria-hidden="true">
        {external ? '↗' : '→'}
      </span>
    )}
  </div>
</Tag>

<style>
  .showcase-preview {
    display: grid;
    grid-template-rows: auto 1fr;
    min-block-size: 100%;
    border: 1px solid var(--color-border);
    border-radius: 1.4rem;
    overflow: hidden;
    background: var(--color-surface-strong);
    box-shadow: var(--shadow-card);
    color: var(--color-text);
    text-decoration: none;
    transition:
      transform var(--duration-normal) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out),
      background-color var(--duration-normal) var(--ease-out);
  }

  .showcase-preview--linked:hover {
    transform: translateY(-4px);
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-card-hover);
    color: var(--color-text);
  }

  .showcase-preview__media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, var(--color-accent-light), transparent 44%),
      var(--color-bg-subtle);
  }

  .showcase-preview__image,
  .showcase-preview__fallback {
    inline-size: 100%;
    block-size: 100%;
  }

  .showcase-preview__fallback {
    display: grid;
    place-items: center;
    padding: var(--space-5);
  }

  .showcase-preview__links,
  .showcase-preview__tags-area {
    inline-size: 100%;
    block-size: 100%;
    padding: var(--space-4);
    padding-block-start: calc(var(--space-4) + 2.5rem);
  }

  .showcase-preview__links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
  }

  .showcase-preview__action {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    min-block-size: 2.25rem;
    padding-inline: var(--space-3);
    border: 1px solid rgba(18, 20, 28, 0.1);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.76);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
  }

  .showcase-preview__action--primary {
    border-color: transparent;
    background: var(--color-accent);
  }

  .showcase-preview__action-icon {
    line-height: 1;
  }

  .showcase-preview__action:hover {
    border-color: rgba(18, 20, 28, 0.2);
    background: rgba(255, 255, 255, 0.92);
    transform: translateY(-1px);
  }

  .showcase-preview__action--primary:hover {
    border-color: transparent;
    background: var(--color-accent-hover);
    box-shadow: 0 12px 22px rgba(31, 199, 191, 0.22);
  }

  .showcase-preview__tags-area {
    display: flex;
    align-items: flex-end;
  }

  .showcase-preview__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
  }

  .showcase-preview__fallback-copy {
    display: inline-flex;
    align-items: center;
    min-block-size: 2rem;
    padding-inline: 0.8rem;
    border: 1px solid rgba(18, 20, 28, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    color: var(--color-text-muted);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .showcase-preview__image {
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .showcase-preview--linked:hover .showcase-preview__image {
    transform: scale(1.04);
  }

  .showcase-preview__label {
    position: absolute;
    inset-inline-start: var(--space-4);
    inset-block-start: var(--space-4);
    display: inline-flex;
    align-items: center;
    min-block-size: 2rem;
    padding-inline: 0.75rem;
    border-radius: 999px;
    background: rgba(18, 20, 28, 0.72);
    color: #f7fbff;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  :global(:root[data-theme='dark']) .showcase-preview__label {
    background: rgba(6, 10, 14, 0.78);
  }

  :global(:root[data-theme='dark']) .showcase-preview__fallback-copy {
    border-color: rgba(247, 251, 255, 0.12);
    background: rgba(6, 10, 14, 0.72);
    color: var(--color-text);
  }

  :global(:root[data-theme='dark']) .showcase-preview__action {
    border-color: rgba(247, 251, 255, 0.12);
    background: rgba(6, 10, 14, 0.72);
  }

  :global(:root[data-theme='dark']) .showcase-preview__action--primary {
    border-color: transparent;
    background: var(--color-accent);
  }

  .showcase-preview__body {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
    padding: 1.1rem 1.15rem 1.2rem;
  }

  .showcase-preview__copy {
    display: grid;
    gap: 0.35rem;
  }

  .showcase-preview__meta {
    max-inline-size: none;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .showcase-preview__title {
    font-size: clamp(1.05rem, 0.96rem + 0.35vw, 1.35rem);
    line-height: 1.22;
    letter-spacing: -0.02em;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .showcase-preview__title-link {
    color: inherit;
    text-decoration: none;
  }

  .showcase-preview__title-link:hover {
    text-decoration: underline;
  }

  .showcase-preview__description {
    max-inline-size: none;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: 1.55;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .showcase-preview__icon {
    flex: none;
    color: var(--color-text-muted);
    font-size: 1.15rem;
    line-height: 1;
    transform: translateY(0.15rem);
  }

  .showcase-preview--compact {
    inline-size: clamp(22rem, 29vw, 28rem);
  }

  @media (prefers-reduced-motion: reduce) {
    .showcase-preview__image,
    .showcase-preview {
      transition: none;
    }

    .showcase-preview--linked:hover {
      transform: none;
    }

    .showcase-preview--linked:hover .showcase-preview__image {
      transform: none;
    }
  }
</style>

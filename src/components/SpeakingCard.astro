---
interface MediaLink {
  label: string;
  url: string;
}

interface Props {
  id?: string;
  title?: string;
  format?: string;
  location?: string;
  year?: string;
  audience?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  links?: MediaLink[];
  insights?: string[];
  featured?: boolean;
  imageLoading?: 'eager' | 'lazy';
  summaryHref?: string;
}

const {
  id,
  title,
  format,
  location,
  year,
  audience,
  description,
  image,
  imageAlt,
  links = [],
  insights = [],
  featured = false,
  imageLoading = 'lazy',
  summaryHref,
} = Astro.props;

const normalizedImage =
  image && image.startsWith('/') && !image.startsWith('//')
    ? `${import.meta.env.BASE_URL}${image.slice(1)}`
    : image;
---

<article id={id} class:list={['card speaking-card', { 'speaking-card--featured': featured }]}>
  {normalizedImage && (
    <div class="speaking-card__image-wrap">
      <img
        src={normalizedImage}
        alt={imageAlt ?? ''}
        width="1600"
        height="900"
        class="speaking-card__image"
        loading={imageLoading}
        decoding="async"
      />
    </div>
  )}

  <div class="speaking-card__body">
    {(format || year) && (
      <div class="speaking-card__eyebrow">
        {format && <span class="tag">{format}</span>}
        {year && <span class="speaking-card__year text-muted text-xs">{year}</span>}
      </div>
    )}

    {title && <h3 class="speaking-card__title">{title}</h3>}

    {(location || audience) && (
      <p class="speaking-card__meta text-muted text-sm">
        {location}
        {location && audience ? ' · ' : ''}
        {audience}
      </p>
    )}

    {description && (
      <p class="speaking-card__desc">{description}</p>
    )}

    {insights && insights.length > 0 && (
      <div class="speaking-card__insights">
        <span class="speaking-card__insights-label">Key Insights</span>
        <ul class="speaking-card__insights-list">
          {insights.map((insight) => (
            <li>{insight}</li>
          ))}
        </ul>
      </div>
    )}

    {(summaryHref || links.length > 0) && (
      <div class="speaking-card__actions">
        {summaryHref && (
          <a href={summaryHref} class="speaking-card__summary-link">
            <span>Summary</span>
            <span aria-hidden="true">→</span>
          </a>
        )}

        {links.length > 0 && (
          <ul class="speaking-card__links" role="list" aria-label={`Related links for ${title ?? 'speaking event'}`}>
            {links.map(({ label, url }) => (
              <li>
                <a
                  href={url}
                  class="speaking-card__link"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={title ? `${label}: ${title}` : label}
                >
                  <span>{label}</span>
                  <span aria-hidden="true">↗</span>
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>
    )}
  </div>
</article>

<style>
  .speaking-card {
    display: flex;
    flex-direction: column;
    block-size: 100%;
    padding: 0;
    overflow: hidden;
  }

  .speaking-card__image-wrap {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-bg-subtle);
  }

  .speaking-card__image {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .speaking-card:hover .speaking-card__image {
    transform: scale(1.03);
  }

  @media (prefers-reduced-motion: reduce) {
    .speaking-card:hover .speaking-card__image {
      transform: none;
    }
  }

  .speaking-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6);
    flex: 1;
  }

  .speaking-card__eyebrow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .speaking-card__year {
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .speaking-card__title {
    font-size: clamp(1.45rem, 1.16rem + 0.6vw, 1.9rem);
    font-weight: 600;
    line-height: var(--leading-snug);
  }

  .speaking-card--featured .speaking-card__title {
    font-size: clamp(1.6rem, 1.3rem + 0.9vw, 2.2rem);
  }

  .speaking-card__meta {
    max-inline-size: none;
  }

  .speaking-card__desc {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    max-inline-size: none;
  }

  .speaking-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
  }

  .speaking-card__links li + li {
    margin-block-start: 0;
  }

  .speaking-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
    margin-block-start: auto;
  }

  .speaking-card__summary-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    min-block-size: 2.25rem;
    padding-inline: var(--space-3);
    border-radius: 999px;
    background: var(--color-accent);
    color: var(--color-text);
    font-size: var(--text-xs);
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition:
      background-color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
  }

  .speaking-card__summary-link:hover {
    background: var(--color-accent-hover);
    color: var(--color-text);
    transform: translateY(-1px);
    box-shadow: 0 12px 22px rgba(31, 199, 191, 0.22);
  }

  .speaking-card__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    min-block-size: 2.25rem;
    padding: 0 var(--space-3);
    border: 1px solid rgba(26, 26, 26, 0.1);
    border-radius: 999px;
    color: var(--color-text);
    font-size: var(--text-xs);
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.02em;
    background: rgba(255, 255, 255, 0.74);
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .speaking-card__link:hover {
    border-color: rgba(26, 26, 26, 0.2);
    background: rgba(255, 255, 255, 0.92);
    color: var(--color-text);
    transform: translateY(-1px);
  }

  .speaking-card__insights {
    display: grid;
    gap: var(--space-2);
    padding: var(--space-4);
    background: rgba(31, 199, 191, 0.08);
    border-radius: 1rem;
    font-size: var(--text-sm);
  }

  .speaking-card__insights-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .speaking-card__insights-list {
    margin: 0;
    padding-inline-start: 1.25em;
    color: var(--color-text-muted);
  }

  .speaking-card__insights-list li + li {
    margin-block-start: 0.25em;
  }

  @media (min-width: 64rem) {
    .speaking-card--featured .speaking-card__body {
      padding: var(--space-6);
    }
  }
</style>

---
interface MediaLink {
  label: string;
  url: string;
}

interface Props {
  title?: string;
  format?: string;
  location?: string;
  year?: string;
  audience?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  links?: MediaLink[];
  featured?: boolean;
  imageLoading?: 'eager' | 'lazy';
}

const {
  title,
  format,
  location,
  year,
  audience,
  description,
  image,
  imageAlt,
  links = [],
  featured = false,
  imageLoading = 'lazy',
} = Astro.props;

const normalizedImage =
  image && image.startsWith('/') && !image.startsWith('//')
    ? `${import.meta.env.BASE_URL}${image.slice(1)}`
    : image;
---

<article class:list={['card speaking-card', { 'speaking-card--featured': featured }]}>
  {normalizedImage && (
    <div class="speaking-card__image-wrap">
      <img
        src={normalizedImage}
        alt={imageAlt ?? ''}
        width="1600"
        height="900"
        class="speaking-card__image"
        loading={imageLoading}
        decoding="async"
      />
    </div>
  )}

  <div class="speaking-card__body">
    {(format || year) && (
      <div class="speaking-card__eyebrow">
        {format && <span class="tag">{format}</span>}
        {year && <span class="speaking-card__year text-muted text-xs">{year}</span>}
      </div>
    )}

    {title && <h3 class="speaking-card__title">{title}</h3>}

    {(location || audience) && (
      <p class="speaking-card__meta text-muted text-sm">
        {location}
        {location && audience ? ' · ' : ''}
        {audience}
      </p>
    )}

    {description && (
      <p class="speaking-card__desc">{description}</p>
    )}

    {links.length > 0 && (
        <ul class="speaking-card__links" role="list" aria-label={`Related links for ${title ?? 'speaking event'}`}>
          {links.map(({ label, url }) => (
            <li>
              <a
                href={url}
                class="speaking-card__link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={title ? `${label}: ${title}` : label}
              >
                <span>{label}</span>
                <span aria-hidden="true">↗</span>
              </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</article>

<style>
  .speaking-card {
    display: flex;
    flex-direction: column;
    block-size: 100%;
    padding: 0;
    overflow: hidden;
  }

  .speaking-card__image-wrap {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-bg-subtle);
  }

  .speaking-card__image {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .speaking-card:hover .speaking-card__image {
    transform: scale(1.03);
  }

  @media (prefers-reduced-motion: reduce) {
    .speaking-card:hover .speaking-card__image {
      transform: none;
    }
  }

  .speaking-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    flex: 1;
  }

  .speaking-card__eyebrow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .speaking-card__year {
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .speaking-card__title {
    font-size: var(--text-lg);
    font-weight: 600;
    line-height: var(--leading-snug);
  }

  .speaking-card--featured .speaking-card__title {
    font-size: var(--text-xl);
  }

  .speaking-card__meta {
    max-inline-size: none;
  }

  .speaking-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    max-inline-size: none;
  }

  .speaking-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
    margin-block-start: auto;
  }

  .speaking-card__links li + li {
    margin-block-start: 0;
  }

  .speaking-card__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text);
    font-size: var(--text-xs);
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }

  .speaking-card__link:hover {
    border-color: var(--color-accent);
    background: var(--color-accent-light);
    color: var(--color-text);
  }

  @media (min-width: 64rem) {
    .speaking-card--featured .speaking-card__body {
      padding: var(--space-6);
    }
  }
</style>

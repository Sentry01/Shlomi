---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import SocialLinks from '@/components/SocialLinks.astro';

const metrics = [
  {
    value: 'US$900K → US$18M ARR',
    label: 'GitHub AppSec growth across APJ in under three years',
  },
  {
    value: '25+ years',
    label: 'Enterprise technology across engineering, security, and GTM',
  },
  {
    value: '4× Presidents Club',
    label: 'Recognized across multiple stages of the career',
  },
  {
    value: '350+ test harness',
    label: 'Autonomous harness run used to prove long-running agent workflows',
  },
];

const timeline = [
  {
    period: '2024 – Present',
    title: 'AI GTM Lead, GitHub Copilot',
    company: 'GitHub',
    summary:
      'Own GTM execution for GitHub Copilot across APJ. Work spans executive engagement, competitive positioning, field enablement, and hands-on demonstrations of practical AI and agentic engineering workflows.',
  },
  {
    period: '2021 – 2024',
    title: 'Application Security Lead / Senior Application Security Lead',
    company: 'GitHub',
    summary:
      'Built and scaled GitHub’s AppSec business across APAC. Grew the practice from an early-stage motion into a material ARR business while establishing repeatable plays for secrets management and developer-first security adoption.',
  },
  {
    period: '2019 – 2021',
    title: 'Sales Director, Advanced Technology Group',
    company: 'Proofpoint',
    summary:
      'Led advanced technology growth across ANZ, closing strategic deals in a difficult market and helping customers navigate cloud security, data protection, and modern security architecture decisions.',
  },
  {
    period: '2017 – 2019',
    title: 'Regional Sales Director',
    company: 'Illumio',
    summary:
      'Opened the ANZ market for micro-segmentation, exceeded quota materially, and helped enterprise customers translate zero-trust concepts into deployable programs.',
  },
  {
    period: '2016 – 2019',
    title: 'Co-Founder & CTO',
    company: 'CloudPurge',
    summary:
      'Built a cybersecurity startup from concept to MVP. Drove product direction and technical execution across AWS, Kubernetes, Chromium, and WebRTC while raising seed funding and validating the market.',
  },
  {
    period: '2010 – 2017',
    title: 'Fortify / Voltage leadership roles',
    company: 'Hewlett Packard Enterprise',
    summary:
      'Led security revenue growth across Fortify and Voltage Data Security. Built enterprise programs with banks, telcos, and government agencies, growing software security revenue from a small base to a scaled ARR business.',
  },
  {
    period: '2002 – 2010',
    title: 'Sales, presales, and consulting leadership roles',
    company: 'Mercury and Revolution IT',
    summary:
      'Developed the commercial and technical muscle memory for large enterprise software programs — from test automation and observability tooling to broader engineering consultancy growth.',
  },
  {
    period: '1999 – 2002',
    title: 'Systems and security roles',
    company: 'Earlier roles in Israel',
    summary:
      'Started in hands-on infrastructure and security roles at Pelephone and Xeonet, building the operator mindset that still shapes how I evaluate technical systems and enterprise risk.',
  },
];

const personStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Shlomi Shaki',
  url: 'https://sentry01.github.io/Shlomi/about/',
  jobTitle: 'AI GTM Lead, GitHub Copilot',
  description:
    'Enterprise technology leader working across AI GTM, security, engineering, and practical builder workflows.',
  sameAs: ['https://github.com/Sentry01', 'https://www.linkedin.com/in/shlomi'],
  worksFor: {
    '@type': 'Organization',
    name: 'GitHub',
  },
  knowsAbout: [
    'AI go-to-market',
    'Application security',
    'Developer platforms',
    'Agentic engineering',
  ],
};
---

<BaseLayout
  title="About"
  description="About Shlomi Shaki — enterprise technology leader working across AI GTM, security, engineering, and hands-on builder workflows."
  structuredData={personStructuredData}
>
  <Hero class="about-hero">
    <span slot="eyebrow" class="hero-eyebrow">About</span>
    <h1 slot="title" class="about-hero__title">
      Commercial operator. Technical translator. Builder by instinct.
    </h1>

    <p>
      I have spent more than 25 years working across enterprise software, cybersecurity, and
      engineering. The through-line has stayed consistent: help technical teams earn executive
      confidence, and help executives make bets that stand up to technical reality.
    </p>
    <p>
      Today I lead GitHub Copilot go-to-market across APJ. Before that I built GitHub’s
      application security business in the region, ran growth roles at Proofpoint and Illumio,
      co-founded a cybersecurity startup, and spent years in software quality, infrastructure,
      and security roles. I still like to build. Demos, field tooling, agent workflows, and
      test-first systems are how I keep the strategy grounded.
    </p>

    <div slot="actions" class="about-hero__actions">
      <div class="profile-links">
        <span class="profile-links__label">Profiles</span>
        <SocialLinks />
      </div>
    </div>
  </Hero>

  <section class="section">
    <div class="container">
      <ul class="metrics-strip" role="list">
        {metrics.map((metric) => (
          <li class="metrics-strip__item card">
            <span class="metrics-strip__value">{metric.value}</span>
            <span class="metrics-strip__label">{metric.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container about-intro">
      <div class="section-heading prose">
        <span class="section-heading__eyebrow">Approach</span>
        <h2>Where executive context and technical credibility meet.</h2>
        <p>
          I work best at the seam between boardroom language and builder reality. That means
          translating complex product shifts into clear commercial moves, then backing the story
          with practical artifacts that engineers and field teams can actually use.
        </p>
      </div>

      <div class="about-pillars grid">
        <article class="card about-pillar">
          <h3>Lead with business outcomes</h3>
          <p>
            Growth matters when it is repeatable. I focus on adoption plays, competitive
            positioning, and field execution that moves revenue and builds durable trust.
          </p>
        </article>

        <article class="card about-pillar">
          <h3>Stay close to the tooling</h3>
          <p>
            I build harnesses, demos, and practical agent workflows because real technical depth
            sharpens the message and exposes weak assumptions early.
          </p>
        </article>

        <article class="card about-pillar">
          <h3>Make complexity usable</h3>
          <p>
            Enterprise change fails when it is hard to explain. My job is to simplify without
            flattening the truth.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" id="career-timeline">
    <div class="container">
      <div class="section-heading prose">
        <span class="section-heading__eyebrow">Career timeline</span>
        <h2>A career built across growth, security, and engineering.</h2>
        <p>
          The titles changed. The pattern did not: earn trust, solve hard enterprise problems,
          and stay technical enough to know what will actually work.
        </p>
      </div>

      <ol class="timeline" role="list">
        {timeline.map((entry) => (
          <li class="timeline__item">
            <article class="card timeline-card">
              <p class="timeline-card__period">{entry.period}</p>
              <div class="timeline-card__header">
                <h3>{entry.title}</h3>
                <p class="timeline-card__company">{entry.company}</p>
              </div>
              <p>{entry.summary}</p>
            </article>
          </li>
        ))}
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    padding-block-end: var(--space-8);
  }

  .about-hero__title {
    max-inline-size: 14ch;
  }

  .about-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
  }

  .button-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-block-size: 2.75rem;
    padding: 0 var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 600;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }

  .button-link:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text);
  }

  .button-link--primary {
    background: var(--color-text);
    border-color: var(--color-text);
    color: var(--color-bg);
  }

  .button-link--primary:hover {
    background: #2a2a2a;
    border-color: #2a2a2a;
    color: var(--color-bg);
  }

  .profile-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
  }

  .profile-links__label,
  .section-heading__eyebrow,
  .timeline-card__period {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .metrics-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 14rem), 1fr));
    gap: var(--space-4);
    list-style: none;
  }

  .metrics-strip__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-block-size: 100%;
  }

  .metrics-strip__value {
    font-size: var(--text-xl);
    font-weight: 700;
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .metrics-strip__label {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }

  .about-intro {
    display: grid;
    gap: var(--space-8);
  }

  .section-heading {
    display: grid;
    gap: var(--space-3);
  }

  .about-pillars {
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
  }

  .about-pillar {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .about-pillar h3,
  .timeline-card__header h3 {
    font-size: var(--text-lg);
  }

  .about-pillar p,
  .timeline-card p {
    color: var(--color-text-muted);
  }

  .timeline {
    display: grid;
    gap: var(--space-4);
    list-style: none;
    margin-block-start: var(--space-8);
  }

  .timeline__item {
    padding: 0;
  }

  .timeline-card {
    display: grid;
    gap: var(--space-3);
  }

  .timeline-card__header {
    display: grid;
    gap: var(--space-1);
  }

  .timeline-card__company {
    color: var(--color-text);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  @media (min-width: 48rem) {
    .timeline {
      gap: var(--space-5);
    }

    .timeline-card {
      grid-template-columns: minmax(8rem, 10rem) 1fr;
      align-items: start;
    }

    .timeline-card__period {
      padding-block-start: 0.35rem;
    }

    .timeline-card__header,
    .timeline-card > p:last-child {
      grid-column: 2;
    }
  }
</style>

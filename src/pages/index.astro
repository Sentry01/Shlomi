---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ShowcasePreviewCard from '@/components/ShowcasePreviewCard.astro';
import {
  speakingEvents,
  speakingEventDateLabel,
  speakingEventSlug,
  speakingEventSortValue,
} from '@/data/speaking';
import { blogSlug, isExternalCanonical } from '@/lib/blog';

const baseUrl = import.meta.env.BASE_URL;
const heroPhoto = `${baseUrl}images/hero-shlomi-portrait.png`;
const heroPhotoAlt = 'Portrait of Shlomi Shaki.';
const heroPhotoWidth = 2256;
const heroPhotoHeight = 2623;

interface ShowcaseItem {
  label: string;
  title: string;
  href: string;
  image?: string;
  imageAlt?: string;
  meta?: string;
  description?: string;
  external?: boolean;
}

const featuredProjects = (await getCollection('projects'))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .slice(0, 3);

const latestPosts = (await getCollection('blog'))
  .filter(({ data }) => !data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const featuredSpeaking = speakingEvents
  .map((event, index) => ({
    ...event,
    image: event.images?.[0],
    dateLabel: speakingEventDateLabel(event.date),
    sortValue: speakingEventSortValue(event.date),
    originalIndex: index,
  }))
  .filter((event) => event.image)
  .sort((a, b) => {
    if (b.sortValue !== a.sortValue) return b.sortValue - a.sortValue;
    return a.originalIndex - b.originalIndex;
  })
  .slice(0, 3);

const articleItems: ShowcaseItem[] = latestPosts.map((post) => {
  const slug = blogSlug(post.id);
  const canonicalHref = post.data.canonical;
  const href = isExternalCanonical(canonicalHref) && canonicalHref
    ? canonicalHref
    : `${baseUrl}blog/${slug}/`;

  return {
    label: 'Article',
    title: post.data.title,
    href,
    meta: post.data.pubDate.toLocaleDateString('en-US', {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
      timeZone: 'UTC',
    }),
    description: post.data.description,
    external: isExternalCanonical(post.data.canonical),
  };
});

const projectItems: ShowcaseItem[] = featuredProjects.map((project) => ({
  label: 'Project',
  title: project.data.title,
  href: `${baseUrl}projects/${project.id.replace(/\.md$/, '')}/`,
  meta: project.data.tags?.slice(0, 2).join(' · '),
  description: project.data.description,
}));

const speakingItems: ShowcaseItem[] = featuredSpeaking.map((event) => ({
  label: 'Speaking',
  title: event.title,
  href: `${baseUrl}speaking/#${speakingEventSlug(event.title)}`,
  image: event.image,
  imageAlt: event.imageAlt ?? event.title,
  meta: event.dateLabel ?? event.format,
  description: event.summary,
}));
---

<BaseLayout
  title="Shlomi Shaki"
  description="Writing, speaking, and projects on practical AI engineering, enterprise adoption, and software trust."
  mainClass="home-page"
>
  <section class="home-hero">
    <div class="home-hero__shell">
      <div class="container home-hero__inner">
        <div class="home-hero__content">
          <div class="home-hero__headline-block">
            <p class="home-hero__eyebrow">GTM Strategy · AI engineering · cyber security</p>
            <h1 class="home-hero__title">
              <span class="home-hero__title-line">Deep Enterprise Architecture</span>
              <span class="home-hero__title-accent">GTM Execution</span>
            </h1>
          </div>

          <div class="home-hero__support">
            <p class="home-hero__intro">
              Hi, I am Shlomi, I combine deep technology expertise in Software Engineering,
              Enterprise Architecture, Cyber Security and Agentic AI with Executive
              Communication, Sales, Marketing and Delivery experience to scale technology GTM in
              global markets.
            </p>
            <div class="home-hero__actions">
              <a class="hero-button hero-button--primary" href="#projects">View Projects</a>
              <a class="hero-button hero-button--secondary" href="#articles">Read Articles</a>
              <a class="hero-button hero-button--secondary" href="#speaking">Speaking</a>
            </div>
          </div>

          <figure class="home-hero__media">
            <img
              src={heroPhoto}
              alt={heroPhotoAlt}
              width={heroPhotoWidth}
              height={heroPhotoHeight}
              class="home-hero__image"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </figure>
        </div>
      </div>
    </div>
  </section>

  <section class="section showcase-section" id="speaking">
    <div class="container showcase-section__header">
      <div>
        <p class="showcase-section__eyebrow">Speaking</p>
        <h2>Recent talks, panels, and Events.</h2>
      </div>
      <a class="section-link" href={`${baseUrl}speaking/`}>All speaking</a>
    </div>

    {speakingItems.length > 0 ? (
      <div class="container showcase-section__grid">
        {speakingItems.map((item) => (
          <ShowcasePreviewCard
            label={item.label}
            title={item.title}
            href={item.href}
            image={item.image}
            imageAlt={item.imageAlt}
            meta={item.meta}
            description={item.description}
          />
        ))}
      </div>
    ) : (
      <div class="container">
        <p class="showcase-section__empty">Speaking highlights will appear here soon.</p>
      </div>
    )}
  </section>

  <section class="section showcase-section showcase-section--soft" id="articles">
    <div class="container showcase-section__header">
      <div>
        <p class="showcase-section__eyebrow">Articles</p>
        <h2>Blog articles from the field.</h2>
      </div>
      <a class="section-link" href={`${baseUrl}blog/`}>All articles</a>
    </div>

    {articleItems.length > 0 ? (
      <div class="container showcase-section__grid">
        {articleItems.map((item) => (
          <ShowcasePreviewCard
            label={item.label}
            title={item.title}
            href={item.href}
            image={item.image}
            imageAlt={item.imageAlt}
            meta={item.meta}
            description={item.description}
            external={item.external}
          />
        ))}
      </div>
    ) : (
      <div class="container">
        <p class="showcase-section__empty">Articles will appear here soon.</p>
      </div>
    )}
  </section>

  <section class="section showcase-section" id="projects">
    <div class="container showcase-section__header">
      <div>
        <p class="showcase-section__eyebrow">Projects</p>
        <h2>Agentic AI Projects.</h2>
      </div>
      <a class="section-link" href={`${baseUrl}projects/`}>All projects</a>
    </div>

    {projectItems.length > 0 ? (
      <div class="container showcase-section__grid">
        {projectItems.map((item) => (
          <ShowcasePreviewCard
            label={item.label}
            title={item.title}
            href={item.href}
            image={item.image}
            imageAlt={item.imageAlt}
            description={item.description}
          />
        ))}
      </div>
    ) : (
      <div class="container">
        <p class="showcase-section__empty">Projects will appear here soon.</p>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  :global(main.home-page) {
    background: var(--color-bg);
  }

  .home-hero {
    position: relative;
    padding-block-end: 0;
  }

  .home-hero__shell {
    display: grid;
    min-block-size: auto;
    border-block-end: 1px solid var(--color-border);
    background:
      radial-gradient(circle at top right, rgba(52, 184, 173, 0.16), transparent 32%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.18), transparent 44%),
      var(--color-hero-panel);
  }

  .home-hero__inner {
    display: grid;
    align-items: center;
    min-block-size: clamp(38rem, 78vh, 50rem);
    max-inline-size: min(100%, var(--container-max));
    margin-inline: auto;
    padding-block: clamp(4rem, 7.5vh, 6rem);
  }

  .home-hero__content {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 24rem);
    grid-template-areas:
      'headline headline'
      'support media';
    align-items: start;
    justify-items: start;
    justify-self: stretch;
    column-gap: clamp(2rem, 4vw, 4rem);
    row-gap: clamp(1.75rem, 3vw, 2.8rem);
    inline-size: 100%;
    max-inline-size: none;
  }

  .home-hero__headline-block,
  .home-hero__support,
  .home-hero__media {
    min-inline-size: 0;
  }

  .home-hero__headline-block {
    grid-area: headline;
    display: grid;
    gap: clamp(1rem, 1.6vw, 1.3rem);
    max-inline-size: 100%;
  }

  .home-hero__support {
    grid-area: support;
    display: grid;
    gap: var(--space-5);
    max-inline-size: 37rem;
    justify-self: start;
    padding-block-end: 0;
  }

  .home-hero__eyebrow {
    max-inline-size: none;
    margin: 0;
    color: var(--color-accent);
    font-size: clamp(0.76rem, 0.72rem + 0.14vw, 0.86rem);
    font-weight: 600;
    letter-spacing: 0.26em;
    text-transform: uppercase;
  }

  .home-hero__title {
    display: grid;
    gap: clamp(0.28rem, 0.75vw, 0.5rem);
    max-inline-size: 100%;
    margin: 0;
    font-size: clamp(3.2rem, 5.8vw, 5.1rem);
    line-height: 0.88;
    letter-spacing: -0.07em;
  }

  .home-hero__title-line,
  .home-hero__title-accent {
    display: block;
    white-space: nowrap;
  }

  .home-hero__title-accent {
    color: var(--color-accent-strong);
    font-size: 0.9em;
    padding-block-start: clamp(0.12rem, 0.45vw, 0.28rem);
  }

  .home-hero__intro {
    max-inline-size: 35rem;
    margin: 0;
    color: var(--color-text-muted);
    font-size: clamp(1.08rem, 1rem + 0.4vw, 1.34rem);
    line-height: 1.56;
  }

  .home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 0.75rem;
    margin-block-start: var(--space-3);
  }

  .home-hero__media {
    grid-area: media;
    position: relative;
    inline-size: min(100%, 22rem);
    margin: 0;
    justify-self: end;
  }

  .home-hero__image {
    display: block;
    inline-size: 100%;
    block-size: auto;
  }

  :global(:root[data-theme='dark']) .home-hero__media {
    background:
      radial-gradient(circle at 50% 14%, var(--color-accent-light), transparent 48%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.08), transparent 64%),
      var(--color-bg-subtle);
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-block-size: 3.05rem;
    padding-inline: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 0.8rem;
    background: var(--color-surface);
    color: var(--color-text);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition:
      transform var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
  }

  .hero-button:hover {
    transform: translateY(-1px);
    border-color: var(--color-border-hover);
    color: var(--color-text);
  }

  .hero-button--primary {
    border-color: transparent;
    background: var(--color-accent);
    box-shadow: 0 16px 32px rgba(52, 184, 173, 0.22);
  }

  .hero-button--primary:hover {
    background: var(--color-accent-hover);
  }

  .showcase-section {
    position: relative;
    padding-block: clamp(4rem, 8vw, 6rem);
  }

  .showcase-section + .showcase-section {
    border-block-start: 1px solid var(--color-border);
  }

  .showcase-section--soft {
    background:
      linear-gradient(180deg, var(--color-accent-light), transparent 28%),
      var(--color-bg);
  }

  .showcase-section__header {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-4);
    margin-block-end: var(--space-8);
  }

  .showcase-section__header h2 {
    max-inline-size: 12ch;
    font-size: clamp(2.4rem, 2rem + 1.8vw, 4.2rem);
    letter-spacing: -0.045em;
  }

  .showcase-section__eyebrow {
    max-inline-size: none;
    margin-block-end: var(--space-3);
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    min-block-size: 3rem;
    padding-inline: 1rem 1.15rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface);
    color: var(--color-text);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
  }

  .section-link::after {
    content: '→';
    margin-inline-start: 0.5rem;
  }

  .section-link:hover {
    color: var(--color-text);
    border-color: var(--color-border-hover);
    background: var(--color-surface-strong);
  }

  .showcase-section__grid {
    display: grid;
    gap: var(--space-6);
  }

  .showcase-section__empty {
    color: var(--color-text-muted);
  }

  @media (min-width: 48rem) {
    .showcase-section__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 47.99rem) {
    .home-hero__shell {
      min-block-size: auto;
    }

    .home-hero__inner {
      min-block-size: auto;
      padding-block-start: 4.75rem;
      padding-block-end: 4rem;
    }

    .home-hero__content {
      grid-template-columns: 1fr;
      grid-template-areas:
        'headline'
        'support'
        'media';
      gap: var(--space-6);
      text-align: left;
    }

    .home-hero__support {
      max-inline-size: none;
      justify-self: stretch;
      padding-block-end: 0;
    }

    .home-hero__title {
      font-size: clamp(3rem, 12vw, 4.15rem);
      margin-inline: 0;
    }

    .home-hero__title-line,
    .home-hero__title-accent {
      white-space: normal;
    }

    .home-hero__intro {
      max-inline-size: 28rem;
      font-size: clamp(1.05rem, 0.96rem + 0.7vw, 1.24rem);
      margin-inline: 0;
    }

    .home-hero__actions {
      flex-wrap: wrap;
      justify-content: flex-start;
    }

    .home-hero__media {
      inline-size: min(100%, 22rem);
      justify-self: start;
    }

    .showcase-section__header h2 {
      max-inline-size: 14ch;
    }
  }
</style>

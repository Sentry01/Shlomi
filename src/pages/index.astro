---
import { getCollection } from 'astro:content';
import BlogPostCard from '@/components/BlogPostCard.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import SpeakingCard from '@/components/SpeakingCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  speakingEvents,
  speakingEventDateLabel,
  speakingEventSlug,
  speakingEventSortValue,
} from '@/data/speaking';
import { isExternalCanonical, blogSlug } from '@/lib/blog';

const baseUrl = import.meta.env.BASE_URL;

// Get featured projects (top 3)
const featuredProjects = (await getCollection('projects'))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .slice(0, 3);

// Get latest posts (excluding drafts in production)
const latestPosts = (await getCollection('blog'))
  .filter(({ data }) => !data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

// Select the latest three speaking events that have both imagery and insights
const featuredSpeaking = speakingEvents
  .map((event, index) => ({
    ...event,
    image: event.images?.[0],
    sortValue: speakingEventSortValue(event.date),
    originalIndex: index,
  }))
  .filter((event) => event.image && event.insights && event.insights.length > 0)
  .sort((a, b) => {
    if (b.sortValue !== a.sortValue) return b.sortValue - a.sortValue;
    return a.originalIndex - b.originalIndex;
  })
  .slice(0, 3);
---

<BaseLayout
  title="Shlomi Shaki"
  description="Writing, speaking, and projects on practical AI engineering, enterprise adoption, and software trust."
  mainClass="home-page"
>
  <section class="home-hero">
    <div class="container">
      <div class="home-hero__panel">
        <span class="home-hero__eyebrow">Writing · speaking · building</span>
        <h1 class="home-hero__title">
          Turning AI ambition
          <span>into software that ships.</span>
        </h1>
        <p class="home-hero__intro">
          I lead GitHub Copilot across APJ and use this site to publish what I am seeing in the
          field — enterprise AI adoption, agentic engineering, software trust, and the projects
          behind the ideas.
        </p>
        <div class="home-hero__actions">
          <a class="hero-button hero-button--primary" href="#articles">Latest articles</a>
          <a class="hero-button hero-button--secondary" href="#projects">Projects</a>
          <a class="hero-button hero-button--secondary" href="#speaking">Speaking</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="speaking">
    <div class="container">
      <div class="showcase-section">
        <div class="showcase-section__header">
          <div class="showcase-section__intro prose">
            <span class="showcase-section__eyebrow">Speaking</span>
            <h2>Recent rooms, roundtables, and stages.</h2>
            <p>
              Three recent events with the sharpest takeaways, plus a direct path into the full
              archive.
            </p>
          </div>
          <a class="section-link" href={`${baseUrl}speaking/`}>All events</a>
        </div>

        {featuredSpeaking.length > 0 ? (
          <div class="showcase-grid showcase-grid--speaking">
            {featuredSpeaking.map((event, index) => (
              <SpeakingCard
                title={event.title}
                format={event.format}
                year={speakingEventDateLabel(event.date)}
                location={event.region}
                audience={event.audience}
                description={event.summary}
                insights={event.insights?.slice(0, 2)}
                image={event.image}
                imageAlt={event.imageAlt ?? event.title}
                links={event.sourceLinks}
                summaryHref={`${baseUrl}speaking/#${speakingEventSlug(event.title)}`}
                imageLoading={index === 0 ? 'eager' : 'lazy'}
              />
            ))}
          </div>
        ) : (
          <p class="showcase-empty">Speaking highlights will appear here soon.</p>
        )}
      </div>
    </div>
  </section>

  <section class="section" id="articles">
    <div class="container">
      <div class="showcase-section showcase-section--soft">
        <div class="showcase-section__header">
          <div class="showcase-section__intro prose">
            <span class="showcase-section__eyebrow">Articles</span>
            <h2>Latest writing from the field.</h2>
            <p>
              Recent posts on AI adoption, agentic engineering, software trust, and what teams
              actually need to ship.
            </p>
          </div>
          <a class="section-link" href={`${baseUrl}blog/`}>All articles</a>
        </div>

        {latestPosts.length > 0 ? (
          <div class="showcase-grid showcase-grid--articles">
            {latestPosts.map((post) => (
              <BlogPostCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                href={isExternalCanonical(post.data.canonical)
                  ? post.data.canonical
                  : `${baseUrl}blog/${blogSlug(post.id)}/`}
                isExternal={isExternalCanonical(post.data.canonical)}
              />
            ))}
          </div>
        ) : (
          <p class="showcase-empty">New writing is on the way.</p>
        )}
      </div>
    </div>
  </section>

  <section class="section" id="projects">
    <div class="container">
      <div class="showcase-section">
        <div class="showcase-section__header">
          <div class="showcase-section__intro prose">
            <span class="showcase-section__eyebrow">Projects</span>
            <h2>Projects behind the arguments.</h2>
            <p>
              Tools, experiments, and product ideas that make the writing concrete and give the
              talks something real to point at.
            </p>
          </div>
          <a class="section-link" href={`${baseUrl}projects/`}>All projects</a>
        </div>

        {featuredProjects.length > 0 ? (
          <div class="showcase-grid showcase-grid--projects">
            {featuredProjects.map((project) => (
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                tags={project.data.tags}
                href={`${baseUrl}projects/${project.id.replace(/\.md$/, '')}/`}
                repoUrl={project.data.repo}
                liveUrl={project.data.liveUrl}
              />
            ))}
          </div>
        ) : (
          <p class="showcase-empty">Featured projects will appear here soon.</p>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  :global(main.home-page) {
    background:
      radial-gradient(circle at top left, rgba(49, 201, 192, 0.16), transparent 34%),
      radial-gradient(circle at top right, rgba(49, 201, 192, 0.08), transparent 24%),
      var(--color-bg);
  }

  .home-hero {
    position: relative;
    padding-block-start: clamp(6.5rem, 12vh, 9rem);
    padding-block-end: var(--space-12);
  }

  .home-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top left, rgba(49, 201, 192, 0.14), transparent 38%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.28), transparent 72%);
    pointer-events: none;
  }

  .home-hero__panel {
    position: relative;
    display: grid;
    gap: var(--space-6);
    max-inline-size: 72rem;
    padding-block: clamp(var(--space-8), 5vw, var(--space-12));
  }

  .home-hero__eyebrow {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: var(--color-accent-hover);
  }

  .home-hero__title {
    max-inline-size: 10ch;
    font-size: clamp(4rem, 9vw, 8.5rem);
    line-height: 0.9;
    letter-spacing: -0.06em;
  }

  .home-hero__title span {
    color: var(--color-accent);
  }

  .home-hero__intro {
    max-inline-size: 48rem;
    font-size: clamp(1.125rem, 1rem + 0.55vw, 1.45rem);
    line-height: 1.65;
    color: var(--color-text-muted);
  }

  .home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-block-size: 3.75rem;
    padding-inline: clamp(1.35rem, 3vw, 1.9rem);
    border-radius: 999px;
    border: 1px solid rgba(17, 17, 17, 0.1);
    font-size: var(--text-base);
    font-weight: 700;
    text-decoration: none;
    transition:
      transform var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
  }

  .hero-button:hover {
    transform: translateY(-2px);
  }

  .hero-button--primary {
    background: var(--color-accent);
    color: var(--color-text);
    border-color: transparent;
    box-shadow: 0 18px 30px rgba(49, 201, 192, 0.22);
  }

  .hero-button--primary:hover {
    background: var(--color-accent-hover);
    color: var(--color-text);
  }

  .hero-button--secondary {
    background: rgba(255, 253, 248, 0.86);
    color: var(--color-text);
  }

  .hero-button--secondary:hover {
    border-color: rgba(49, 201, 192, 0.45);
    background: rgba(49, 201, 192, 0.08);
    color: var(--color-text);
  }

  .showcase-section {
    display: grid;
    gap: clamp(var(--space-6), 4vw, var(--space-10));
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border: 1px solid rgba(17, 17, 17, 0.06);
    border-radius: 1.75rem;
    background: rgba(255, 253, 248, 0.78);
    box-shadow: 0 20px 48px rgba(17, 17, 17, 0.06);
    backdrop-filter: blur(10px);
  }

  .showcase-section--soft {
    background:
      linear-gradient(180deg, rgba(49, 201, 192, 0.08), rgba(255, 253, 248, 0.82)),
      rgba(255, 253, 248, 0.82);
  }

  .showcase-section__header {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .showcase-section__intro {
    max-inline-size: 42rem;
  }

  .showcase-section__intro :global(h2) {
    font-size: clamp(2rem, 1.6rem + 1vw, 2.8rem);
  }

  .showcase-section__eyebrow {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent-hover);
    margin-block-end: var(--space-2);
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
  }

  .section-link::after {
    content: '→';
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .section-link:hover::after {
    transform: translateX(4px);
  }

  .showcase-grid {
    display: grid;
    gap: var(--space-5);
  }

  .showcase-grid > * {
    min-block-size: 100%;
  }

  .showcase-grid :global(.card) {
    block-size: 100%;
  }

  .showcase-grid--articles :global(.blog-card__title) {
    font-size: clamp(1.55rem, 1.26rem + 0.7vw, 2rem);
  }

  .showcase-grid--projects :global(.project-card),
  .showcase-grid--articles :global(.blog-card),
  .showcase-grid--speaking :global(.speaking-card) {
    background: var(--color-surface);
  }

  .showcase-empty {
    color: var(--color-text-muted);
    padding: var(--space-4) 0;
  }

  @media (min-width: 48rem) {
    .showcase-grid--articles,
    .showcase-grid--projects {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .showcase-grid--speaking {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 72rem) {
    .showcase-grid--articles,
    .showcase-grid--projects,
    .showcase-grid--speaking {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

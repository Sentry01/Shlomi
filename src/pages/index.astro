---
import { getCollection } from 'astro:content';
import BlogPostCard from '@/components/BlogPostCard.astro';
import Hero from '@/components/Hero.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import SocialLinks from '@/components/SocialLinks.astro';
import SpeakingCard from '@/components/SpeakingCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { speakingEvents } from '@/data/speaking';
import { isExternalCanonical, blogSlug } from '@/lib/blog';

const baseUrl = import.meta.env.BASE_URL;

const featuredProjects = (await getCollection('projects'))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .slice(0, 3);

const latestPosts = (await getCollection('blog'))
  // .filter(({ data }) => !data.draft) // Show all posts for showcase
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const leadPost = latestPosts[0];
const supportingPosts = latestPosts.slice(1);

const speakingHighlight =
  speakingEvents.find(({ title }) => title === 'OctoNihon Tokyo User Group') ?? speakingEvents[0];
---

<BaseLayout
  title="Shlomi Shaki"
  description="Executive-plus-builder leader across AI GTM, application security, enterprise growth, and practical agentic engineering."
  mainClass="home-page"
>
  <Hero backgroundImage="/images/hero-rko-stage.png" imageLayout="stacked" class="home-hero">
    <span slot="eyebrow" class="hero-eyebrow">Writing · speaking · projects</span>
    <h1 slot="title" class="home-hero__title">
      Dispatches on AI delivery, practical engineering, and the work behind the talks.
    </h1>

    <div class="home-hero__intro home-hero__story">
      <p>
        This homepage is intentionally closer to a publication than a profile: essays on AI
        engineering and adoption, selected talks, and the projects that make the ideas concrete.
      </p>
      <p>
        The About page covers background. This page is for the current body of work — what I am
        writing, presenting, and shipping in public right now.
      </p>
    </div>

    <div slot="actions" class="home-hero__aside">
      <div class="home-hero__aside-copy">
        <span class="home-hero__aside-label">Now publishing</span>
        <p>
          New essays, event notes, and project breakdowns from the field — with the supporting
          artifacts close at hand.
        </p>
      </div>

      <div class="home-hero__cta-group">
        <a class="button-link button-link--primary" href="#latest-writing">Read latest</a>
        <a class="button-link" href={`${baseUrl}speaking/`}>Speaking</a>
        <a class="button-link" href={`${baseUrl}projects/`}>Projects</a>
      </div>

      <div class="home-hero__profiles">
        <span class="home-hero__profiles-label">Elsewhere</span>
        <SocialLinks class="home-hero__socials" />
      </div>
    </div>
  </Hero>

  <section class="section section--writing" id="latest-writing">
    <div class="container home-section">
      <div class="home-section__header">
        <div class="section-heading section-heading--wide prose">
          <span class="section-heading__eyebrow">Latest writing</span>
          <h2>Essays rooted in what teams actually have to ship.</h2>
          <p>
            Recent posts connect AI engineering, software trust, and the work of making adoption
            real beyond the keynote slide.
          </p>
        </div>

        <a class="section-link" href={`${baseUrl}blog/`}>View all writing</a>
      </div>

      {leadPost && (
        <div class="writing-showcase">
          <div class="writing-showcase__lead">
            <BlogPostCard
              title={leadPost.data.title}
              description={leadPost.data.description}
              pubDate={leadPost.data.pubDate}
              tags={leadPost.data.tags}
              href={isExternalCanonical(leadPost.data.canonical)
                ? leadPost.data.canonical
                : `${baseUrl}blog/${blogSlug(leadPost.id)}/`}
              isExternal={isExternalCanonical(leadPost.data.canonical)}
            />
          </div>

          {supportingPosts.length > 0 && (
            <div class="writing-showcase__rail">
              {supportingPosts.map((post) => (
                <BlogPostCard
                  title={post.data.title}
                  description={post.data.description}
                  pubDate={post.data.pubDate}
                  tags={post.data.tags}
                  href={isExternalCanonical(post.data.canonical)
                    ? post.data.canonical
                    : `${baseUrl}blog/${blogSlug(post.id)}/`}
                  isExternal={isExternalCanonical(post.data.canonical)}
                />
              ))}
            </div>
          )}
        </div>
      )}
    </div>
  </section>

  <section class="section section--collections" id="speaking-and-projects">
    <div class="container home-section">
      <div class="home-collections__intro prose">
        <span class="section-heading__eyebrow">From the field</span>
        <h2>Talks and projects that keep the writing grounded in real rooms and real builds.</h2>
        <p>
          The public side of the work: conference rooms, user groups, and the software artifacts
          that turn an argument into something concrete.
        </p>
      </div>

      <div class="home-collections__grid">
        <section class="collection-panel collection-panel--speaking">
          <div class="section-heading prose">
            <span class="section-heading__eyebrow">Speaking</span>
            <h2>Talks, roundtables, and public conversations.</h2>
            <p>
              A selection of recent appearances on AI delivery, developer productivity, and
              practical software trust.
            </p>
          </div>

          <SpeakingCard
            title={speakingHighlight.title}
            format={speakingHighlight.format}
            year={speakingHighlight.date}
            location={speakingHighlight.region}
            audience={speakingHighlight.audience}
            description={speakingHighlight.summary}
            image={speakingHighlight.images?.[0]}
            imageAlt={speakingHighlight.imageAlt ?? speakingHighlight.title}
            links={speakingHighlight.sourceLinks}
            featured
            imageLoading="eager"
          />

          <a class="section-link" href={`${baseUrl}speaking/`}>Browse all speaking events</a>
        </section>

        <section class="collection-panel collection-panel--projects" id="featured-work">
          <div class="section-heading prose">
            <span class="section-heading__eyebrow">Projects</span>
            <h2>Projects that turn ideas into something you can inspect.</h2>
            <p>
              Selected builds spanning agent orchestration, Copilot workflows, and practical
              tooling that supports the writing.
            </p>
          </div>

          <div class="project-stack">
            {featuredProjects.map((project) => (
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                tags={project.data.tags}
                href={`${baseUrl}projects/${project.id.replace(/\.md$/, '')}/`}
                repoUrl={project.data.repo}
                liveUrl={project.data.liveUrl}
              />
            ))}
          </div>

          <a class="section-link" href={`${baseUrl}projects/`}>Explore the full project archive</a>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  :global(main.home-page) {
    position: relative;
    overflow: clip;
    background:
      radial-gradient(circle at 14% 0%, rgba(222, 197, 207, 0.32), transparent 22rem),
      radial-gradient(circle at 86% 16%, rgba(243, 236, 231, 0.88), transparent 18rem),
      linear-gradient(180deg, #f4ebe6 0%, #f7f1ed 24rem, #fbf8f5 50rem, var(--color-bg) 100%);
  }

  :global(main.home-page)::before {
    content: '';
    position: absolute;
    inset: 7rem auto auto -8rem;
    inline-size: 18rem;
    block-size: 18rem;
    border-radius: 999px;
    background: rgba(223, 195, 208, 0.18);
    filter: blur(28px);
    pointer-events: none;
  }

  :global(main.home-page .container) {
    max-inline-size: 96rem; /* Widen container for better breathing room */
  }

  .home-hero__title {
    max-inline-size: 15ch; /* Allow slightly wider title */
    font-size: clamp(3rem, 2.5rem + 2.5vw, 5.5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .home-hero :global(.hero__content) {
    inline-size: 100%; /* Remove inner constraint */
  }

  .home-hero :global(.hero__body) {
    max-inline-size: none;
  }

  .home-hero__intro {
    display: grid;
    gap: var(--space-5);
    max-inline-size: 54rem; /* Widen intro text block */
    font-size: var(--text-lg); /* Bump size slightly for impact */
    line-height: var(--leading-relaxed);
  }

  .home-hero__cta-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .home-hero__aside {
    display: grid;
    gap: var(--space-5);
    align-content: start;
    padding: clamp(var(--space-5), 3vw, var(--space-7));
    border: 1px solid rgba(58, 48, 54, 0.08);
    border-radius: 1.5rem;
    background:
      linear-gradient(180deg, rgba(255, 252, 249, 0.96) 0%, rgba(247, 238, 233, 0.88) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.65),
      0 18px 36px rgba(48, 38, 44, 0.06);
  }

  .home-hero__aside-copy {
    display: grid;
    gap: var(--space-2);
  }

  .home-hero__profiles {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
  }

  .home-hero__socials :global(.social-links) {
    gap: var(--space-3);
  }

  .home-hero__aside-label,
  .home-hero__profiles-label,
  .section-heading__eyebrow {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .home-hero__aside-label,
  .home-hero__profiles-label {
    color: rgba(26, 26, 26, 0.56);
  }

  .home-hero__aside-copy p {
    max-inline-size: none;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .button-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-block-size: 3rem;
    padding: 0 var(--space-5);
    border: 1px solid rgba(26, 26, 26, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 14px 32px rgba(48, 38, 44, 0.08);
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 600;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .button-link:hover {
    border-color: rgba(26, 26, 26, 0.26);
    background: rgba(255, 255, 255, 0.94);
    color: var(--color-text);
    transform: translateY(-2px);
  }

  .button-link--primary {
    background: var(--color-text);
    border-color: var(--color-text);
    color: var(--color-bg);
  }

  .button-link--primary:hover {
    background: #2a2a2a;
    border-color: #2a2a2a;
    color: var(--color-bg);
  }

  .home-section,
  .collection-panel,
  .writing-showcase__lead,
  .writing-showcase__rail,
  .section-heading {
    display: grid;
    gap: var(--space-5);
  }

  .home-section {
    gap: clamp(var(--space-6), 3vw, var(--space-8));
  }

  .home-section__header {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .section--writing {
    padding-block-start: clamp(var(--space-16), 8vw, var(--space-24));
  }

  .section--collections {
    padding-block-start: clamp(var(--space-14), 7vw, var(--space-20));
  }

  .section-heading--wide {
    max-inline-size: 46rem;
  }

  .section-heading p {
    color: var(--color-text-muted);
  }

  .writing-showcase {
    display: grid;
    gap: clamp(var(--space-5), 3vw, var(--space-8));
  }

  .writing-showcase__lead :global(.card),
  .writing-showcase__rail :global(.card),
  .collection-panel {
    border-color: rgba(58, 48, 54, 0.08);
    box-shadow: 0 22px 56px rgba(48, 38, 44, 0.08);
  }

  .writing-showcase__lead :global(.card) {
    min-block-size: 100%;
    padding: clamp(var(--space-8), 4vw, var(--space-10));
    border-radius: 2rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(250, 246, 242, 0.9) 100%);
  }

  .writing-showcase__lead :global(.blog-card__header) {
    gap: var(--space-3);
  }

  .writing-showcase__lead :global(.blog-card__title) {
    font-size: clamp(1.75rem, 1.35rem + 1vw, 2.35rem);
    max-inline-size: 15ch;
  }

  .writing-showcase__lead :global(.blog-card__desc) {
    font-size: var(--text-base);
    max-inline-size: 38rem;
  }

  .writing-showcase__rail :global(.card),
  .project-stack :global(.card),
  .collection-panel {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9) 0%, rgba(248, 244, 240, 0.82) 100%);
  }

  .writing-showcase__rail :global(.card) {
    padding: clamp(var(--space-5), 3vw, var(--space-6));
    border-radius: 1.5rem;
    block-size: 100%;
  }

  .section-heading__eyebrow {
    color: var(--color-text-muted);
  }

  .collection-panel {
    padding: clamp(var(--space-6), 3.5vw, var(--space-10));
    border: 1px solid rgba(58, 48, 54, 0.08);
    border-radius: 2rem;
  }

  .home-collections__intro {
    max-inline-size: 52rem;
    margin-block-end: var(--space-2);
  }

  .home-collections__grid {
    display: grid;
    gap: clamp(var(--space-6), 3vw, var(--space-8));
  }

  .collection-panel--speaking :global(.speaking-card) {
    max-inline-size: none;
    border-radius: 1.5rem;
  }

  .collection-panel--speaking :global(.speaking-card__body) {
    padding: clamp(var(--space-6), 3.5vw, var(--space-8));
  }

  .collection-panel--projects :global(.project-card) {
    padding: clamp(var(--space-6), 3vw, var(--space-7));
    border-radius: 1.5rem;
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    inline-size: fit-content;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
  }

  .section-link::after {
    content: '→';
    color: rgba(26, 26, 26, 0.52);
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .section-link:hover::after {
    transform: translateX(3px);
  }

  .project-stack {
    display: grid;
    gap: var(--space-5);
  }

  .project-stack :global(.project-card) {
    gap: var(--space-5);
  }

  .project-stack :global(.project-card__desc) {
    max-inline-size: none;
  }

  @media (max-width: 42rem) {
    .home-section__header,
    .home-hero__profiles {
      flex-direction: column;
      align-items: start;
    }

    .home-hero__cta-group {
      inline-size: 100%;
    }

    .home-hero__cta-group .button-link {
      flex: 1 1 10rem;
    }
  }

  @media (min-width: 64rem) {
    .home-hero :global(.hero__content) {
      display: grid;
      grid-template-columns: minmax(0, 1.8fr) minmax(20rem, 0.9fr); /* Adjust ratio */
      column-gap: clamp(var(--space-8), 6vw, var(--space-16)); /* More generous gap */
      row-gap: var(--space-6);
      align-items: start;
    }

    .home-hero :global(.hero-eyebrow),
    .home-hero__title {
      grid-column: 1 / -1;
    }

    .home-hero :global(.hero__body) {
      grid-column: 1;
      padding-inline-end: clamp(var(--space-2), 1vw, var(--space-6));
    }

    .home-hero__aside {
      grid-column: 2;
      grid-row: 3;
      align-self: stretch;
      padding: 0 0 0 clamp(var(--space-5), 2.5vw, var(--space-7));
      border: 0;
      border-inline-start: 1px solid rgba(26, 26, 26, 0.08);
      border-radius: 0;
      background: none;
      box-shadow: none;
    }

    .writing-showcase {
      grid-template-columns: minmax(0, 1.6fr) minmax(20rem, 1fr); /* Balance columns */
      gap: clamp(var(--space-6), 4vw, var(--space-10));
      align-items: stretch;
    }

    .writing-showcase__rail {
      grid-template-rows: repeat(2, minmax(0, 1fr));
    }

    .home-collections__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr)); /* Equal width columns */
      gap: clamp(var(--space-6), 4vw, var(--space-10));
      align-items: stretch;
    }
  }
</style>

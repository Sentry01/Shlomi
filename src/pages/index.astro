---
import { getCollection } from 'astro:content';
import BlogPostCard from '@/components/BlogPostCard.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import SpeakingCard from '@/components/SpeakingCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { speakingEvents } from '@/data/speaking';
import { isExternalCanonical, blogSlug } from '@/lib/blog';

const baseUrl = import.meta.env.BASE_URL;

// Get featured projects (top 3)
const featuredProjects = (await getCollection('projects'))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .slice(0, 3);

// Get latest posts (excluding drafts in production)
const latestPosts = (await getCollection('blog'))
  .filter(({ data }) => !data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const leadPost = latestPosts[0];
const supportingPosts = latestPosts.slice(1);

// Select the two speaking events with insights
const featuredSpeaking = speakingEvents
  .filter(event => event.insights && event.insights.length > 0)
  .slice(0, 2);
---

<BaseLayout
  title="Shlomi Shaki"
  description="Executive-plus-builder leader across AI GTM, application security, enterprise growth, and practical agentic engineering."
  mainClass="home-page"
>
  <header class="masthead container">
    <div class="masthead__content prose">
      <span class="masthead__eyebrow">Shlomi Shaki · AI GTM & Engineering</span>
      <h1 class="masthead__title">
        Building the bridge between enterprise strategy and agentic code.
      </h1>
      <p class="masthead__intro">
        Executive leader and hands-on builder. Currently focused on the practical reality of AI adoption: how organizations move from "chat" to "shipping software."
      </p>
    </div>
  </header>

  <section class="section section--writing" id="latest-writing">
    <div class="container home-section">
      <div class="home-section__header">
        <div class="section-heading section-heading--wide prose">
          <span class="section-heading__eyebrow">Latest writing</span>
          <h2>Essays from the field.</h2>
          <p>
            Dispatches on AI engineering, software trust, and making adoption real.
          </p>
        </div>
        <a class="section-link" href={`${baseUrl}blog/`}>View all writing</a>
      </div>

      {leadPost && (
        <div class="writing-showcase">
          <div class="writing-showcase__lead">
            <BlogPostCard
              title={leadPost.data.title}
              description={leadPost.data.description}
              pubDate={leadPost.data.pubDate}
              tags={leadPost.data.tags}
              href={isExternalCanonical(leadPost.data.canonical)
                ? leadPost.data.canonical
                : `${baseUrl}blog/${blogSlug(leadPost.id)}/`}
              isExternal={isExternalCanonical(leadPost.data.canonical)}
            />
          </div>

          {supportingPosts.length > 0 && (
            <div class="writing-showcase__rail">
              {supportingPosts.map((post) => (
                <BlogPostCard
                  title={post.data.title}
                  description={post.data.description}
                  pubDate={post.data.pubDate}
                  tags={post.data.tags}
                  href={isExternalCanonical(post.data.canonical)
                    ? post.data.canonical
                    : `${baseUrl}blog/${blogSlug(post.id)}/`}
                  isExternal={isExternalCanonical(post.data.canonical)}
                />
              ))}
            </div>
          )}
        </div>
      )}
    </div>
  </section>

  <section class="section section--speaking" id="speaking">
    <div class="container home-section">
      <div class="home-section__header">
        <div class="section-heading section-heading--wide prose">
          <span class="section-heading__eyebrow">Speaking</span>
          <h2>Insights from the room.</h2>
          <p>
            Key takeaways from recent roundtables and executive sessions.
          </p>
        </div>
        <a class="section-link" href={`${baseUrl}speaking/`}>View all speaking</a>
      </div>

      <div class="speaking-grid">
        {featuredSpeaking.map((event) => (
          <SpeakingCard
            title={event.title}
            format={event.format}
            year={event.date}
            location={event.region}
            audience={event.audience}
            description={event.summary}
            insights={event.insights}
            image={event.images?.[0]}
            imageAlt={event.imageAlt ?? event.title}
            links={event.sourceLinks}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section section--projects" id="projects">
    <div class="container home-section">
      <div class="home-section__header">
        <div class="section-heading section-heading--wide prose">
          <span class="section-heading__eyebrow">Featured Work</span>
          <h2>Building in public.</h2>
          <p>
            Projects that turn theory into working software.
          </p>
        </div>
        <a class="section-link" href={`${baseUrl}projects/`}>View all projects</a>
      </div>

      <div class="project-grid">
        {featuredProjects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            tags={project.data.tags}
            href={`${baseUrl}projects/${project.id.replace(/\.md$/, '')}/`}
            repoUrl={project.data.repo}
            liveUrl={project.data.liveUrl}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  :global(main.home-page) {
    background: var(--color-bg);
  }

  .masthead {
    padding-block-start: clamp(6rem, 15vh, 10rem);
    padding-block-end: clamp(3rem, 5vh, 5rem);
  }

  .masthead__content {
    max-inline-size: 52rem;
  }

  .masthead__eyebrow {
    display: block;
    margin-block-end: var(--space-4);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .masthead__title {
    font-size: clamp(2.5rem, 2rem + 2.5vw, 4.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-block-end: var(--space-6);
  }

  .masthead__intro {
    font-size: clamp(1.125rem, 1rem + 0.5vw, 1.35rem);
    line-height: 1.6;
    color: var(--color-text-muted);
    max-inline-size: 42rem;
  }

  .home-section {
    display: grid;
    gap: clamp(var(--space-8), 4vw, var(--space-12));
  }

  .home-section__header {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .section-heading--wide {
    max-inline-size: 40rem;
  }

  .section-heading__eyebrow {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-block-end: var(--space-2);
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
  }

  .section-link::after {
    content: '→';
    transition: transform 0.2s ease;
  }

  .section-link:hover::after {
    transform: translateX(4px);
  }

  /* Writing Section */
  .writing-showcase {
    display: grid;
    gap: clamp(var(--space-6), 3vw, var(--space-8));
  }

  .writing-showcase__lead :global(.card) {
    background: var(--color-bg-subtle);
    border: 1px solid rgba(0,0,0,0.04);
    padding: clamp(var(--space-6), 4vw, var(--space-10));
    border-radius: 1.5rem;
  }

  .writing-showcase__lead :global(.blog-card__title) {
    font-size: clamp(1.5rem, 1.25rem + 1vw, 2.25rem);
  }

  .writing-showcase__rail {
    display: grid;
    gap: var(--space-6);
  }

  .writing-showcase__rail :global(.card) {
    height: 100%;
    background: var(--color-bg-subtle);
    border: 1px solid rgba(0,0,0,0.04);
    border-radius: 1.5rem;
    padding: var(--space-6);
  }

  /* Speaking Section */
  .speaking-grid {
    display: grid;
    gap: var(--space-6);
  }

  .speaking-grid :global(.speaking-card) {
    background: var(--color-bg-subtle);
    border: 1px solid rgba(0,0,0,0.04);
    border-radius: 1.5rem;
    overflow: hidden;
  }

  /* Projects Section */
  .project-grid {
    display: grid;
    gap: var(--space-6);
  }

  .project-grid :global(.project-card) {
    background: var(--color-bg-subtle);
    border: 1px solid rgba(0,0,0,0.04);
    border-radius: 1.5rem;
    padding: var(--space-6);
  }

  @media (min-width: 64rem) {
    .writing-showcase {
      grid-template-columns: 1.4fr 1fr;
    }
    
    .speaking-grid {
      grid-template-columns: 1fr 1fr;
    }
    
    .project-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

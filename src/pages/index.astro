---
import { getCollection } from 'astro:content';
import BlogPostCard from '@/components/BlogPostCard.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import SpeakingCard from '@/components/SpeakingCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  speakingEvents,
  speakingEventDateLabel,
  speakingEventSlug,
  speakingEventSortValue,
} from '@/data/speaking';
import { isExternalCanonical, blogSlug } from '@/lib/blog';

const baseUrl = import.meta.env.BASE_URL;

// Get featured projects (top 3)
const featuredProjects = (await getCollection('projects'))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .slice(0, 3);

// Get latest posts (excluding drafts in production)
const latestPosts = (await getCollection('blog'))
  .filter(({ data }) => !data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

// Select the latest three speaking events that have both imagery and insights
const featuredSpeaking = speakingEvents
  .map((event, index) => ({
    ...event,
    image: event.images?.[0],
    sortValue: speakingEventSortValue(event.date),
    originalIndex: index,
  }))
  .filter((event) => event.image && event.insights && event.insights.length > 0)
  .sort((a, b) => {
    if (b.sortValue !== a.sortValue) return b.sortValue - a.sortValue;
    return a.originalIndex - b.originalIndex;
  })
  .slice(0, 3);
---

<BaseLayout
  title="Shlomi Shaki"
  description="Writing, speaking, and projects on practical AI engineering, enterprise adoption, and software trust."
  mainClass="home-page"
>
  <section class="home-hero">
    <div class="container">
      <div class="home-hero__grid">
        <div class="home-hero__headline">
          <span class="home-hero__eyebrow">Writing · speaking · building</span>
          <h1 class="home-hero__title">
            Turning AI ambition
            <span>into software that ships.</span>
          </h1>
        </div>

        <div class="home-hero__support">
          <p class="home-hero__intro">
            I lead GitHub Copilot across APJ and use this site to publish what I am seeing in the
            field — enterprise AI adoption, agentic engineering, software trust, and the projects
            behind the ideas.
          </p>
          <div class="home-hero__actions">
            <a class="hero-button hero-button--primary" href="#articles">Latest articles</a>
            <a class="hero-button hero-button--secondary" href="#projects">Projects</a>
            <a class="hero-button hero-button--secondary" href="#speaking">Speaking</a>
          </div>
          <p class="home-hero__note">
            Start with the newest field notes, then move into recent talks and the projects that
            make the arguments concrete.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section home-section home-section--speaking" id="speaking">
    <div class="container">
      <div class="showcase-section">
        <div class="showcase-section__header">
          <div class="showcase-section__intro prose">
            <span class="showcase-section__eyebrow">Speaking</span>
            <h2>Recent rooms, roundtables, and stages.</h2>
            <p>
              Three recent events with the sharpest takeaways, plus a direct path into the full
              archive.
            </p>
          </div>
          <a class="section-link" href={`${baseUrl}speaking/`}>All events</a>
        </div>

        {featuredSpeaking.length > 0 ? (
          <div class="showcase-grid showcase-grid--speaking">
            {featuredSpeaking.map((event, index) => (
              <SpeakingCard
                title={event.title}
                format={event.format}
                year={speakingEventDateLabel(event.date)}
                location={event.region}
                audience={event.audience}
                description={event.summary}
                insights={event.insights?.slice(0, 2)}
                image={event.image}
                imageAlt={event.imageAlt ?? event.title}
                links={event.sourceLinks?.slice(0, 1)}
                summaryHref={`${baseUrl}speaking/#${speakingEventSlug(event.title)}`}
                imageLoading={index === 0 ? 'eager' : 'lazy'}
                featured={index === 0}
              />
            ))}
          </div>
        ) : (
          <p class="showcase-empty">Speaking highlights will appear here soon.</p>
        )}
      </div>
    </div>
  </section>

  <section class="section home-section home-section--articles" id="articles">
    <div class="container">
      <div class="showcase-section">
        <div class="showcase-section__header">
          <div class="showcase-section__intro prose">
            <span class="showcase-section__eyebrow">Articles</span>
            <h2>Latest writing from the field.</h2>
            <p>
              Recent posts on AI adoption, agentic engineering, software trust, and what teams
              actually need to ship.
            </p>
          </div>
          <a class="section-link" href={`${baseUrl}blog/`}>All articles</a>
        </div>

        {latestPosts.length > 0 ? (
          <div class="showcase-grid showcase-grid--articles">
            {latestPosts.map((post, index) => (
              <BlogPostCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                tags={post.data.tags.slice(0, 3)}
                href={isExternalCanonical(post.data.canonical)
                  ? post.data.canonical
                  : `${baseUrl}blog/${blogSlug(post.id)}/`}
                isExternal={isExternalCanonical(post.data.canonical)}
                variant={index === 0 ? 'lead' : 'default'}
              />
            ))}
          </div>
        ) : (
          <p class="showcase-empty">New writing is on the way.</p>
        )}
      </div>
    </div>
  </section>

  <section class="section home-section home-section--projects" id="projects">
    <div class="container">
      <div class="showcase-section">
        <div class="showcase-section__header">
          <div class="showcase-section__intro prose">
            <span class="showcase-section__eyebrow">Projects</span>
            <h2>Projects behind the arguments.</h2>
            <p>
              Tools, experiments, and product ideas that make the writing concrete and give the
              talks something real to point at.
            </p>
          </div>
          <a class="section-link" href={`${baseUrl}projects/`}>All projects</a>
        </div>

        {featuredProjects.length > 0 ? (
          <div class="showcase-grid showcase-grid--projects">
            {featuredProjects.map((project, index) => (
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                tags={project.data.tags.slice(0, 3)}
                href={`${baseUrl}projects/${project.id.replace(/\.md$/, '')}/`}
                repoUrl={project.data.repo}
                liveUrl={project.data.liveUrl}
                featured={index === 0}
              />
            ))}
          </div>
        ) : (
          <p class="showcase-empty">Featured projects will appear here soon.</p>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  :global(main.home-page) {
    background:
      radial-gradient(circle at top left, rgba(49, 201, 192, 0.2), transparent 28%),
      radial-gradient(circle at 82% 8%, rgba(49, 201, 192, 0.1), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.34), transparent 18%),
      var(--color-bg);
  }

  :global(main.home-page .container) {
    max-inline-size: 92rem;
  }

  .home-hero {
    position: relative;
    overflow: clip;
    padding-block-start: clamp(6rem, 10vh, 8rem);
    padding-block-end: clamp(4.5rem, 10vh, 7rem);
  }

  .home-hero::before {
    content: '';
    position: absolute;
    inset-inline-start: max(-10rem, calc(50% - 48rem));
    inset-block-start: clamp(2rem, 5vh, 4rem);
    inline-size: clamp(18rem, 40vw, 34rem);
    block-size: clamp(18rem, 36vw, 30rem);
    background: radial-gradient(circle at center, rgba(49, 201, 192, 0.18), rgba(49, 201, 192, 0.04) 58%, transparent 74%);
    pointer-events: none;
  }

  .home-hero::after {
    content: '';
    position: absolute;
    inset-inline: 0;
    inset-block-end: 0;
    block-size: 1px;
    background: linear-gradient(90deg, transparent, rgba(17, 17, 17, 0.1), transparent);
  }

  .home-hero__grid {
    position: relative;
    display: grid;
    gap: clamp(var(--space-8), 6vw, var(--space-16));
    align-items: end;
    min-block-size: clamp(32rem, 72svh, 46rem);
  }

  .home-hero__headline {
    display: grid;
    gap: var(--space-6);
    max-inline-size: min(50rem, 100%);
  }

  .home-hero__eyebrow {
    font-size: clamp(0.72rem, 0.65rem + 0.15vw, 0.82rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    color: var(--color-accent-hover);
  }

  .home-hero__title {
    max-inline-size: 8.8ch;
    font-size: clamp(4.4rem, 10vw, 9rem);
    line-height: 0.88;
    letter-spacing: -0.065em;
  }

  .home-hero__title span {
    display: block;
    color: var(--color-accent);
  }

  .home-hero__support {
    display: grid;
    gap: var(--space-5);
    max-inline-size: 31rem;
    padding: clamp(1.25rem, 3vw, 2rem);
    border: 1px solid rgba(17, 17, 17, 0.08);
    border-radius: 1.75rem;
    background: rgba(255, 253, 248, 0.74);
    box-shadow: 0 20px 48px rgba(17, 17, 17, 0.06);
    backdrop-filter: blur(10px);
  }

  .home-hero__intro {
    max-inline-size: none;
    font-size: clamp(1.125rem, 1rem + 0.55vw, 1.45rem);
    line-height: 1.65;
    color: var(--color-text-muted);
  }

  .home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .home-hero__note {
    max-inline-size: none;
    padding-block-start: var(--space-4);
    border-block-start: 1px solid rgba(17, 17, 17, 0.08);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-block-size: 3.75rem;
    padding-inline: clamp(1.35rem, 3vw, 1.9rem);
    border-radius: 999px;
    border: 1px solid rgba(17, 17, 17, 0.1);
    font-size: var(--text-base);
    font-weight: 700;
    text-decoration: none;
    transition:
      transform var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
  }

  .hero-button:hover {
    transform: translateY(-2px);
  }

  .hero-button--primary {
    background: var(--color-accent);
    color: var(--color-text);
    border-color: transparent;
    box-shadow: 0 18px 30px rgba(49, 201, 192, 0.22);
  }

  .hero-button--primary:hover {
    background: var(--color-accent-hover);
    color: var(--color-text);
  }

  .hero-button--secondary {
    background: rgba(255, 253, 248, 0.86);
    color: var(--color-text);
  }

  .hero-button--secondary:hover {
    border-color: rgba(49, 201, 192, 0.45);
    background: rgba(49, 201, 192, 0.08);
    color: var(--color-text);
  }

  .home-section {
    position: relative;
    padding-block: clamp(4.5rem, 8vw, 7rem);
  }

  .home-section + .home-section {
    border-block-start: 1px solid rgba(17, 17, 17, 0.08);
  }

  .home-section--articles {
    background: linear-gradient(180deg, rgba(49, 201, 192, 0.07), rgba(255, 253, 248, 0) 24%);
  }

  .showcase-section {
    display: grid;
    gap: clamp(var(--space-8), 4vw, var(--space-12));
  }

  .showcase-section__header {
    display: grid;
    gap: var(--space-5);
    align-items: start;
  }

  .showcase-section__intro {
    max-inline-size: 46rem;
  }

  .showcase-section__intro :global(h2) {
    font-size: clamp(2.5rem, 2rem + 1.8vw, 4rem);
    max-inline-size: 12ch;
  }

  .showcase-section__eyebrow {
    display: block;
    font-size: clamp(0.72rem, 0.68rem + 0.1vw, 0.8rem);
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-accent-hover);
    margin-block-end: var(--space-2);
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    min-block-size: 3rem;
    padding-inline: 1rem 1.15rem;
    border: 1px solid rgba(17, 17, 17, 0.08);
    border-radius: 999px;
    background: rgba(255, 253, 248, 0.72);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .section-link::after {
    content: '→';
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .section-link:hover {
    border-color: rgba(49, 201, 192, 0.4);
    background: rgba(49, 201, 192, 0.08);
    color: var(--color-text);
    transform: translateY(-1px);
  }

  .section-link:hover::after {
    transform: translateX(4px);
  }

  .showcase-grid {
    display: grid;
    gap: clamp(var(--space-4), 2vw, var(--space-6));
  }

  .showcase-grid > * {
    min-block-size: 100%;
  }

  .showcase-grid :global(.card) {
    block-size: 100%;
    background: rgba(255, 253, 248, 0.9);
  }

  .showcase-grid--speaking :global(.speaking-card--featured),
  .showcase-grid--articles :global(.blog-card--lead),
  .showcase-grid--projects :global(.project-card--featured) {
    background: linear-gradient(135deg, rgba(49, 201, 192, 0.1), rgba(255, 253, 248, 0.96) 60%);
  }

  .showcase-grid--articles :global(.blog-card--lead .blog-card__title) {
    max-inline-size: 13ch;
    font-size: clamp(2.25rem, 1.9rem + 1.5vw, 3.6rem);
  }

  .showcase-grid--projects :global(.project-card--featured .project-card__title) {
    max-inline-size: 12ch;
  }

  .showcase-grid--speaking :global(.speaking-card--featured .speaking-card__title) {
    max-inline-size: 12ch;
  }

  .showcase-empty {
    color: var(--color-text-muted);
    padding: var(--space-4) 0;
  }

  @media (min-width: 64rem) {
    .home-hero__grid {
      grid-template-columns: minmax(0, 1.35fr) minmax(20rem, 0.78fr);
    }

    .home-hero__support {
      justify-self: end;
    }

    .showcase-section__header {
      grid-template-columns: minmax(0, 1fr) auto;
      justify-content: space-between;
    }

    .showcase-grid--speaking {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .showcase-grid--articles,
    .showcase-grid--projects {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .showcase-grid--speaking > :first-child,
    .showcase-grid--articles > :first-child,
    .showcase-grid--projects > :first-child {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 47.99rem) {
    .home-hero {
      padding-block-start: calc(5.25rem + var(--space-4));
    }

    .home-hero__support {
      padding: var(--space-5);
    }

    .home-hero__title {
      max-inline-size: 9ch;
    }

    .hero-button {
      min-block-size: 3.25rem;
    }

    .showcase-section__intro :global(h2) {
      max-inline-size: 10ch;
    }
  }
</style>

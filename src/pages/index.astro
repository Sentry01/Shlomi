---
import { getCollection } from 'astro:content';
import BlogPostCard from '@/components/BlogPostCard.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import SpeakingCard from '@/components/SpeakingCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { speakingEvents } from '@/data/speaking';
import { isExternalCanonical, blogSlug } from '@/lib/blog';

const baseUrl = import.meta.env.BASE_URL;

// Get featured projects (top 3)
const featuredProjects = (await getCollection('projects'))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .slice(0, 3);

// Get latest posts (excluding drafts in production)
const latestPosts = (await getCollection('blog'))
  .filter(({ data }) => !data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const leadPost = latestPosts[0];
const supportingPosts = latestPosts.slice(1);

// Select the two speaking events with insights
const featuredSpeaking = speakingEvents
  .filter(event => event.insights && event.insights.length > 0)
  .slice(0, 2);
---

<BaseLayout
  title="Shlomi Shaki"
  description="Executive-plus-builder leader across AI GTM, application security, enterprise growth, and practical agentic engineering."
  mainClass="home-page"
>
  <section class="section section--cover" id="latest-writing">
    <div class="container">
      <header class="section-header">
        <h2 class="section-title">Latest Writing</h2>
        <a class="section-link" href={`${baseUrl}blog/`}>View all articles</a>
      </header>

      <div class="cover-grid">
        {leadPost && (
          <div class="cover-main">
            <BlogPostCard
              title={leadPost.data.title}
              description={leadPost.data.description}
              pubDate={leadPost.data.pubDate}
              tags={leadPost.data.tags}
              href={isExternalCanonical(leadPost.data.canonical)
                ? leadPost.data.canonical
                : `${baseUrl}blog/${blogSlug(leadPost.id)}/`}
              isExternal={isExternalCanonical(leadPost.data.canonical)}
              variant="lead"
            />
          </div>
        )}

        {supportingPosts.length > 0 && (
          <div class="cover-rail">
            {supportingPosts.map((post) => (
              <BlogPostCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                href={isExternalCanonical(post.data.canonical)
                  ? post.data.canonical
                  : `${baseUrl}blog/${blogSlug(post.id)}/`}
                isExternal={isExternalCanonical(post.data.canonical)}
                variant="compact"
              />
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <section class="section section--speaking" id="speaking">
    <div class="container home-section">
      <div class="home-section__header">
        <div class="section-heading section-heading--wide prose">
          <span class="section-heading__eyebrow">Speaking</span>
          <h2>Insights from the room.</h2>
        </div>
        <a class="section-link" href={`${baseUrl}speaking/`}>View all speaking</a>
      </div>

      <div class="speaking-grid">
        {featuredSpeaking.map((event) => (
          <SpeakingCard
            title={event.title}
            format={event.format}
            year={event.date}
            location={event.region}
            audience={event.audience}
            description={event.summary}
            insights={event.insights}
            image={event.images?.[0]}
            imageAlt={event.imageAlt ?? event.title}
            links={event.sourceLinks}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section section--projects" id="projects">
    <div class="container home-section">
      <div class="home-section__header">
        <div class="section-heading section-heading--wide prose">
          <span class="section-heading__eyebrow">Featured Work</span>
          <h2>Building in public.</h2>
          <p>
            Projects that turn theory into working software.
          </p>
        </div>
        <a class="section-link" href={`${baseUrl}projects/`}>View all projects</a>
      </div>

      <div class="project-grid">
        {featuredProjects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            tags={project.data.tags}
            href={`${baseUrl}projects/${project.id.replace(/\.md$/, '')}/`}
            repoUrl={project.data.repo}
            liveUrl={project.data.liveUrl}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  :global(main.home-page) {
    background: var(--color-bg);
  }

  /* Cover Section */
  .section--cover {
    padding-block-start: clamp(6rem, 12vh, 10rem);
    padding-block-end: var(--space-12);
    min-height: 85vh;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-block-end: var(--space-8);
    border-bottom: 1px solid var(--color-border);
    padding-block-end: var(--space-4);
  }

  .section-title {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .cover-grid {
    display: grid;
    gap: var(--space-8);
  }

  .cover-main :global(.blog-card) {
    border: none;
    background: transparent;
    padding: 0;
  }

  .cover-main :global(.blog-card__title) {
    font-size: clamp(2rem, 1.5rem + 2.5vw, 4rem);
    line-height: 1.1;
    margin-block-end: var(--space-4);
  }

  .cover-main :global(.blog-card__desc) {
    font-size: clamp(1.125rem, 1.05rem + 0.5vw, 1.35rem);
    max-inline-size: 45rem;
    color: var(--color-text-muted);
  }

  .cover-rail {
    display: grid;
    gap: var(--space-6);
    border-top: 1px solid var(--color-border);
    padding-block-start: var(--space-8);
  }

  .cover-rail :global(.blog-card) {
    background: transparent;
    border: none;
    padding: 0;
  }

  .cover-rail :global(.blog-card__title) {
    font-size: var(--text-lg);
  }

  /* Shared Section Utilities */
  .home-section {
    display: grid;
    gap: clamp(var(--space-8), 4vw, var(--space-12));
  }

  .home-section__header {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .section-heading--wide {
    max-inline-size: 40rem;
  }

  .section-heading__eyebrow {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-block-end: var(--space-2);
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
  }

  .section-link::after {
    content: '→';
    transition: transform 0.2s ease;
  }

  .section-link:hover::after {
    transform: translateX(4px);
  }

  @media (min-width: 64rem) {
    .cover-grid {
      grid-template-columns: 2fr 1fr;
      gap: var(--space-12);
      align-items: start;
    }

    .cover-rail {
      border-top: none;
      padding-block-start: 0;
      border-left: 1px solid var(--color-border);
      padding-inline-start: var(--space-8);
      height: 100%;
    }
  }

  /* Speaking Section */
  .speaking-grid {
    display: grid;
    gap: var(--space-6);
  }

  .speaking-grid :global(.speaking-card) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0;
  }

  /* Projects Section */
  .project-grid {
    display: grid;
    gap: var(--space-6);
  }

  .project-grid :global(.project-card) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0;
  }

  @media (min-width: 64rem) {
    .speaking-grid {
      grid-template-columns: 1fr 1fr;
    }
    
    .project-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
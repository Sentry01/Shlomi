---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import type { GetStaticPaths } from 'astro';

import BlogPost from '@/layouts/BlogPost.astro';
import { isExternalCanonical } from '@/lib/blog';

const wordsPerMinute = 200;

const estimateReadingTime = (body: string) => {
  const wordCount = body.trim().split(/\s+/).filter(Boolean).length;
  const minutes = Math.max(1, Math.ceil(wordCount / wordsPerMinute));
  return `${minutes} min read`;
};

export const getStaticPaths: GetStaticPaths = async () => {
  const hasHiddenSegment = (value: string) =>
    value.split('/').some((segment) => segment.startsWith('_') || segment.startsWith('.'));

  const posts = (await getCollection('blog'))
    .filter(
      (post) =>
        !hasHiddenSegment(post.id) && (!import.meta.env.PROD || !post.data.draft),
    )
    .sort((left, right) => right.data.pubDate.valueOf() - left.data.pubDate.valueOf());

  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
};

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const readingTime = estimateReadingTime(post.body ?? '');
const isMirror = isExternalCanonical(post.data.canonical);
---

<BlogPost
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  heroImage={post.data.heroImage}
  heroImageAlt={post.data.title}
  tags={post.data.tags}
  readingTime={readingTime}
  canonicalUrl={post.data.canonical}
  robots={isMirror ? 'noindex,follow' : undefined}
>
  <Content />
</BlogPost>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ShowcasePreviewCard from '@/components/ShowcasePreviewCard.astro';
import SpeakingCard from '@/components/SpeakingCard.astro';
import {
  speakingEvents,
  speakingEventDateLabel,
  speakingEventSlug,
  speakingEventSortValue,
} from '@/data/speaking';

const baseUrl = import.meta.env.BASE_URL;

const events = speakingEvents
  .map((event, index) => ({
    ...event,
    dateLabel: speakingEventDateLabel(event.date),
    image: event.images?.[0],
    sortValue: speakingEventSortValue(event.date),
    originalIndex: index,
  }))
  .sort((a, b) => {
    if (b.sortValue !== a.sortValue) return b.sortValue - a.sortValue;
    return a.originalIndex - b.originalIndex;
  });

const featuredEvents = events.filter((event) => event.image).slice(0, 4);
const archiveEvents = events;
---

<BaseLayout
  title="Speaking"
  description="Selected talks, panels, roundtables, podcasts, and webinars by Shlomi Shaki."
  mainClass="speaking-page"
>
  <section class="section speaking-section speaking-section--lead" id="featured">
    <div class="container speaking-section__header">
      <div>
        <p class="speaking-section__eyebrow">Featured appearances</p>
        <h1>Selected talks, panels, and roundtables worth starting with.</h1>
        <p class="speaking-section__intro">
          Talks, executive roundtables, and community sessions on AI engineering, developer trust,
          application security, and what adoption looks like when teams need to ship and govern at
          the same time.
        </p>
      </div>
      <a class="section-link" href="#archive">Browse archive</a>
    </div>

    {featuredEvents.length > 0 ? (
      <div class="container speaking-feature-grid">
        {featuredEvents.map((event) => (
          <ShowcasePreviewCard
            label="Speaking"
            title={event.title}
            href={`${baseUrl}speaking/#${speakingEventSlug(event.title)}`}
            image={event.image}
            imageAlt={event.imageAlt ?? event.title}
            meta={event.dateLabel ?? event.format}
            description={event.summary}
          />
        ))}
      </div>
    ) : (
      <div class="container">
        <p class="speaking-empty">Featured speaking imagery will appear here soon.</p>
      </div>
    )}
  </section>

  <section class="section speaking-section speaking-section--archive" id="archive">
    <div class="container speaking-section__header">
      <div>
        <p class="speaking-section__eyebrow">Archive</p>
        <h2>Every appearance, with image-first cards wherever media exists.</h2>
      </div>
    </div>

    <div class="container speaking-archive-grid">
      {archiveEvents.map((event) => (
        <SpeakingCard
          id={speakingEventSlug(event.title)}
          title={event.title}
          format={event.format}
          location={event.region}
          year={event.dateLabel}
          audience={event.audience}
          description={event.summary}
          image={event.image}
          imageAlt={event.imageAlt}
          links={event.sourceLinks}
          insights={event.insights?.slice(0, 2)}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  :global(main.speaking-page) {
    background: var(--color-bg);
  }

  .speaking-section__eyebrow {
    max-inline-size: none;
    margin-block-end: var(--space-3);
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .speaking-section {
    padding-block: clamp(4rem, 8vw, 6rem);
  }

  .speaking-section--lead {
    padding-block-start: clamp(4.5rem, 10vw, 7rem);
  }

  .speaking-section + .speaking-section {
    border-block-start: 1px solid var(--color-border);
  }

  .speaking-section__header {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-4);
    margin-block-end: var(--space-8);
  }

  .speaking-section__header :is(h1, h2) {
    max-inline-size: 13ch;
    font-size: clamp(2.1rem, 1.8rem + 1.4vw, 3.6rem);
    letter-spacing: -0.04em;
  }

  .speaking-section__intro {
    max-inline-size: 44rem;
    margin-block-start: var(--space-4);
    color: var(--color-text-muted);
    font-size: clamp(1.08rem, 1rem + 0.34vw, 1.28rem);
    line-height: 1.65;
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    min-block-size: 3rem;
    padding-inline: 1rem 1.15rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface);
    color: var(--color-text);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
  }

  .section-link::after {
    content: '→';
    margin-inline-start: 0.5rem;
  }

  .section-link:hover {
    color: var(--color-text);
    border-color: var(--color-border-hover);
    background: var(--color-surface-strong);
  }

  .speaking-feature-grid,
  .speaking-archive-grid {
    display: grid;
    gap: var(--space-6);
  }

  .speaking-section--archive {
    background:
      linear-gradient(180deg, var(--color-accent-light), transparent 28%),
      var(--color-bg);
  }

  .speaking-empty {
    color: var(--color-text-muted);
  }

  @media (min-width: 48rem) {
    .speaking-feature-grid,
    .speaking-archive-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 72rem) {
    .speaking-feature-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>

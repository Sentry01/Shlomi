---
/**
 * BlogPost layout — shared wrapper for individual blog posts.
 *
 * Wraps BaseLayout with blog-specific metadata and an article
 * structure with optional hero image and publication date.
 *
 * Renders content from the default slot even with minimal props.
 */
import ContentPlaceholder from '@/components/ContentPlaceholder.astro';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  pubDate?: Date | string;
  updatedDate?: Date | string;
  tags?: string[];
  readingTime?: string;
  canonicalUrl?: string;
  /** Robots directive forwarded to BaseLayout (e.g. 'noindex,follow'). */
  robots?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  readingTime,
  canonicalUrl,
  robots,
} = Astro.props;

const pubDateValue = pubDate ? new Date(pubDate) : null;
const hasValidPubDate = !!pubDateValue && !Number.isNaN(pubDateValue.getTime());
const formattedPubDate = hasValidPubDate
  ? pubDateValue.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      timeZone: 'UTC',
    })
  : null;

const updatedDateValue = updatedDate ? new Date(updatedDate) : null;
const hasValidUpdatedDate =
  !!updatedDateValue && !Number.isNaN(updatedDateValue.getTime());
const formattedUpdatedDate = hasValidUpdatedDate
  ? updatedDateValue.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      timeZone: 'UTC',
    })
  : null;

const canonicalHref = canonicalUrl ?? Astro.url.href;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDateValue?.toISOString(),
  dateModified: updatedDateValue?.toISOString() ?? pubDateValue?.toISOString(),
  url: canonicalHref,
  mainEntityOfPage: canonicalHref,
  keywords: tags?.join(', '),
  author: {
    '@type': 'Person',
    name: 'Shlomi Shaki',
    url: 'https://sentry01.github.io/Shlomi/about/',
  },
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogType="article"
  structuredData={structuredData}
  robots={robots}
>
  <article class="blog-post section">
    <div class="container">
      <header class="blog-post__header">
        {(formattedPubDate || readingTime) && (
          <div class="blog-post__meta text-muted text-sm">
            {formattedPubDate && (
              <time class="blog-post__date" datetime={pubDateValue?.toISOString()}>
                {formattedPubDate}
              </time>
            )}
            {formattedPubDate && readingTime && (
              <span aria-hidden="true" class="blog-post__separator">·</span>
            )}
            {readingTime && <span>{readingTime}</span>}
          </div>
        )}

        <h1 class="blog-post__title">{title}</h1>

        {description && (
          <p class="blog-post__lede">{description}</p>
        )}

        {tags && tags.length > 0 && (
          <ul class="blog-post__tags" role="list">
            {tags.map((tag) => (
              <li><span class="tag">{tag}</span></li>
            ))}
          </ul>
        )}

        {canonicalUrl && robots?.includes('noindex') && (
          <p class="blog-post__mirror-note text-sm">
            Originally published at{' '}
            <a href={canonicalUrl} rel="noopener noreferrer">{new URL(canonicalUrl).hostname}</a>.
            This is a local mirror.
          </p>
        )}
      </header>

      <ContentPlaceholder
        label="Article"
        title="Article image placeholder"
        className="blog-post__hero--placeholder"
      />

      <div class="blog-post__content prose body-serif">
        <slot />
      </div>

      {formattedUpdatedDate && (
        <footer class="blog-post__footer">
          <p class="text-muted text-sm">
            Last updated: <time datetime={updatedDateValue?.toISOString()}>
              {formattedUpdatedDate}
            </time>
          </p>
        </footer>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-block-end: var(--space-8);
    max-inline-size: var(--prose-max);
  }

  .blog-post__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }

  .blog-post__date {
    font-weight: 600;
  }

  .blog-post__separator {
    color: var(--color-border-hover);
  }

  .blog-post__title {
    font-size: var(--text-3xl);
    font-weight: 700;
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
  }

  .blog-post__lede {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
    font-family: var(--font-serif);
  }

  .blog-post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
  }

  .blog-post__mirror-note {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .blog-post__content {
    margin-block-end: var(--space-12);
  }

  .blog-post__footer {
    border-block-start: 1px solid var(--color-border);
    padding-block-start: var(--space-6);
  }
</style>
